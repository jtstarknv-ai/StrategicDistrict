<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Strategic District Strategic Plan Builder</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@500;600;700;800&family=Source+Serif+Pro:wght@400;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="css/builder.css">
    <link rel="stylesheet" href="css/toolkit.css">

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/assets/images/favicon.png">
    <link rel="apple-touch-icon" href="/assets/images/apple-touch-icon.png">

    <!-- Supabase Client -->
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>

    <!-- Auth Library -->
    <script src="/js/shared/auth.js"></script>
    <script src="/js/shared/plan-sync.js"></script>

    <!-- Document Generation Libraries -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.8.2/jspdf.plugin.autotable.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/pptxgenjs@3.12.0/dist/pptxgen.bundle.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/docx@8.5.0/build/index.umd.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
</head>
<body>
    <!-- Navigation Tab Bar -->
    <div class="nav-tab-bar">
        <div class="nav-tab-container">
            <div class="nav-tab-left">
                <a href="../index.html" class="nav-home-link">
                    <img src="/assets/images/SDlogo.png" alt="SD" class="nav-home-logo" height="28">
                    <span>Strategic District</span>
                </a>
                <div class="nav-tabs">
                    <a href="../builder/index.html" class="nav-tab active">District Strategic Plan</a>
                    <a href="../builder/dashboard.html" class="nav-tab">Progress Dashboard</a>
                    <a href="../strategic-school/index.html" class="nav-tab nav-tab-school">Strategic School</a>
                </div>
            </div>
            <div class="nav-tab-right" id="builderAuthInfo">
                <!-- Populated by paywall.js -->
            </div>
        </div>
    </div>

    <div class="gradient-bar"></div>
    <div class="container">
        <!-- Sidebar Navigation -->
        <div class="sidebar">
            <div class="sidebar-title"><img src="/assets/images/SDlogo.png" alt="SD" height="36" style="border-radius:6px;">Strategic District</div>
            <div style="padding:0 20px;margin-bottom:12px;font-family:'Inter',sans-serif;font-size:0.6875rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--brown);">Strategic Plan Builder</div>
            <ul class="steps-list">
                <li class="step-item active" data-step="1" onclick="stepGoto(1)">1. District Profile</li>
                <li class="step-item" data-step="2" onclick="stepGoto(2)">2. Vision & Mission</li>
                <li class="step-item" data-step="3" onclick="stepGoto(3)">3. Core Values</li>
                <li class="step-item" data-step="4" onclick="stepGoto(4)">4. Competencies</li>
                <li class="step-item" data-step="5" onclick="stepGoto(5)">5. Strategic Domains</li>
                <li class="step-item" data-step="6" onclick="stepGoto(6)">6. Strategic Goal Setting</li>
                <li class="step-item" data-step="7" onclick="stepGoto(7)">7. Strategic Goal Forecasting</li>
                <li class="step-item" data-step="8" onclick="stepGoto(8)">8. Central Office Alignment</li>
                <li class="step-item" data-step="9" onclick="stepGoto(9)">9. Action Initiatives</li>
                <li class="step-item" data-step="10" onclick="stepGoto(10)">10. Implementation Calendar</li>
                <li class="step-item" data-step="11" onclick="stepGoto(11)">11. Review & Finalize</li>
            </ul>

        </div>

        <!-- Main Content Area -->
        <div class="main-content">
            <div class="content-panel">
                <!-- STEP 1: District Profile -->
                <div class="step-content active" data-step="1">
                    <div class="step-actions-bar">
                        <button class="btn btn-clear" onclick="clearStep(1)">Clear This Step</button>
                        <button class="btn btn-clear-all" onclick="clearEntirePlan()">Clear Entire Plan</button>
                    </div>
                    <h1 class="step-title">District Profile</h1>
                    <div id="savedPlansDropdown" style="margin-bottom:1rem;display:none">
                        <label style="font-weight:600;color:#22333B;font-size:0.9rem">Resume a Previously Finalized Plan</label>
                        <select id="savedPlanSelect" onchange="loadSavedPlan()" style="width:100%;padding:0.6rem;border:1px solid #e0e0e0;border-radius:6px;font-size:0.9rem;font-family:Inter,sans-serif;margin-top:0.5rem">
                            <option value="">Start fresh...</option>
                        </select>
                    </div>
                    <div class="plan-name-section" style="background: linear-gradient(135deg, rgba(0,180,204,0.06) 0%, rgba(110,207,110,0.06) 100%); border: 2px solid rgba(0,180,204,0.15); border-left: 4px solid var(--pop-teal); border-radius: 10px; padding: 20px 24px; margin-bottom: 28px;">
                        <h3 style="font-size: 14px; font-weight: 700; color: var(--pop-teal); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 8px;">Name Your Plan</h3>
                        <p style="font-size: 13px; color: #777; margin-bottom: 12px;">Name your plan to save progress. Return any time to continue building.</p>
                        <div style="display: flex; gap: 10px; align-items: flex-end;">
                            <input type="text" id="planNameTop" placeholder="e.g., WCSD 2025-2028 Strategic Plan" value="" oninput="planState.planName=this.value; saveFormState(); updatePlanNameDisplay();" style="flex: 1; padding: 12px 14px; border: 2px solid #E8E8E8; border-radius: 8px; font-size: 14px; font-family: Inter, sans-serif;">
                            <button type="button" class="btn btn-secondary" onclick="submitPlanName()" style="white-space: nowrap;">Save Name</button>
                            <span id="planNameFeedback" style="font-size: 13px; color: #6ECF6E; font-weight: 600; min-width: 60px; text-align: center;"></span>
                        </div>
                    </div>

                    <div class="section-purpose">
                        Every great plan starts with understanding where you are. We'll capture your district's demographics, performance data, and current challenges so we can build a strategy that's grounded in reality. Search for your district below to get started.
                    </div>

                    <!-- Search and Auto-Fill Section -->
                    <div class="custom-input-section">
                        <label>Search for Your District (Optional Auto-Fill)</label>
                        <input type="text" id="districtSearchInput" placeholder="Type your district name..." oninput="handleDistrictSearch(event)" style="margin-bottom: 0.75rem;">
                        <div id="districtSuggestions" style="margin-bottom: 1rem;"></div>
                        <div id="autoFillStatus" style="font-size: 0.9rem; color: #666;"></div>
                        <div style="font-size: 0.85rem; color: var(--brown); margin-top: 0.5rem; line-height: 1.5; padding: 10px 14px; background: rgba(212,165,55,0.08); border-left: 3px solid var(--pop-gold); border-radius: 4px;">If your district is not found, fill out the information below. Nothing is required, but the more you provide, the stronger your strategic plan will be.</div>
                    </div>

                    <!-- District Information Form -->
                    <div class="form-row">
                        <div class="form-group">
                            <label for="districtName">District Name</label>
                            <input type="text" id="districtName" placeholder="e.g., Lincoln Unified School District">
                        </div>
                        <div class="form-group">
                            <label for="districtLocation">Location (City/County)</label>
                            <input type="text" id="districtLocation" placeholder="e.g., Springfield, County">
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label for="studentEnrollment">Total Student Enrollment</label>
                            <input type="number" id="studentEnrollment" placeholder="e.g., 15000">
                        </div>
                        <div class="form-group">
                            <label for="numberOfSchools">Number of Schools</label>
                            <input type="number" id="numberOfSchools" placeholder="e.g., 25">
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label for="teacherCount">Teacher Count</label>
                            <input type="number" id="teacherCount" placeholder="e.g., 900">
                        </div>
                        <div class="form-group">
                            <label for="studentTeacherRatio">Student-Teacher Ratio</label>
                            <input type="text" id="studentTeacherRatio" placeholder="e.g., 16.7:1">
                        </div>
                    </div>

                    <h3 style="margin-top: 2rem; margin-bottom: 1rem; color: #22333B;">Demographic Profile</h3>
                    <div class="form-row">
                        <div class="form-group">
                            <label for="frlRate">Free/Reduced Lunch Rate (%)</label>
                            <input type="number" id="frlRate" placeholder="e.g., 62" min="0" max="100">
                        </div>
                        <div class="form-group">
                            <label for="iepRate">IEP Rate (%)</label>
                            <input type="number" id="iepRate" placeholder="e.g., 14" min="0" max="100">
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label for="elRate">English Learner Rate (%)</label>
                            <input type="number" id="elRate" placeholder="e.g., 28" min="0" max="100">
                        </div>
                        <div class="form-group">
                            <label for="minorityRate">Students of Color (%)</label>
                            <input type="number" id="minorityRate" placeholder="e.g., 78" min="0" max="100">
                        </div>
                    </div>

                    <h3 style="margin-top: 2rem; margin-bottom: 1rem; color: #22333B;">Performance Indicators</h3>
                    <div class="form-row">
                        <div class="form-group">
                            <label for="graduationRate">Graduation Rate (%)</label>
                            <input type="number" id="graduationRate" placeholder="e.g., 87" min="0" max="100">
                        </div>
                        <div class="form-group">
                            <label for="readingProficiency">Reading Proficiency (%)</label>
                            <input type="number" id="readingProficiency" placeholder="e.g., 45" min="0" max="100">
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label for="mathProficiency">Math Proficiency (%)</label>
                            <input type="number" id="mathProficiency" placeholder="e.g., 38" min="0" max="100">
                        </div>
                        <div class="form-group">
                            <label for="chronicAbsRate">Chronic Absenteeism Rate (%)</label>
                            <input type="number" id="chronicAbsRate" placeholder="e.g., 18" min="0" max="100">
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label for="suspensionRate">Suspension Rate (%)</label>
                            <input type="number" id="suspensionRate" placeholder="e.g., 8" min="0" max="100">
                        </div>
                        <div class="form-group">
                            <label for="courseFailureRate">Course Failure Rate (%)</label>
                            <input type="number" id="courseFailureRate" placeholder="e.g., 12" min="0" max="100">
                        </div>
                    </div>

                    <h3 style="margin-top: 2rem; margin-bottom: 1rem; color: #22333B;">Resources & Context</h3>
                    <div class="form-row">
                        <div class="form-group">
                            <label for="childPovertyRate">Child Poverty Rate (%)</label>
                            <input type="number" id="childPovertyRate" placeholder="e.g., 24" min="0" max="100">
                        </div>
                        <div class="form-group">
                            <label for="teacherRetentionRate">Teacher Retention Rate (%)</label>
                            <input type="number" id="teacherRetentionRate" placeholder="e.g., 82" min="0" max="100">
                        </div>
                    </div>
                    <textarea id="keyChallenge" style="display:none"></textarea>

                    <div class="section-divider" style="margin:2.5rem 0;"></div>

                    <div class="template-library" id="templateLibrary">
                        <h2 style="font-family:'Source Serif Pro',serif;font-size:1.3rem;color:#22333B;margin:0 0 0.25rem 0;">
                            <svg viewBox="0 0 24 24" fill="none" stroke="#D4A537" stroke-width="2" width="22" height="22" style="vertical-align:middle;margin-right:8px;"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
                            Template Library
                        </h2>
                        <p style="font-size:0.88rem;color:#5E503F;margin:0 0 1.5rem 0;">Start from a research-backed template instead of a blank canvas. Templates pre-fill vision, mission, values, domains, and goals based on your district profile.</p>
                        
                        <div style="display:flex;gap:0.75rem;margin-bottom:1.25rem;flex-wrap:wrap;">
                            <button class="template-filter-btn active" onclick="filterTemplates('all', this)">All</button>
                            <button class="template-filter-btn" onclick="filterTemplates('size', this)">By District Size</button>
                            <button class="template-filter-btn" onclick="filterTemplates('framework', this)">By Framework</button>
                            <button class="template-filter-btn" onclick="filterTemplates('focus', this)">By Focus Area</button>
                        </div>
                        
                        <div id="templateGrid" style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
                            <!-- Rendered dynamically -->
                        </div>
                        
                        <div id="templatePreview" style="display:none;margin-top:1.5rem;padding:1.5rem;background:#faf8f5;border:2px solid #00B4CC;border-radius:12px;">
                            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem;">
                                <h3 id="templatePreviewTitle" style="font-family:'Source Serif Pro',serif;font-size:1.1rem;color:#22333B;margin:0;"></h3>
                                <button class="btn btn-clear" onclick="document.getElementById('templatePreview').style.display='none'" style="font-size:0.8rem;">Close Preview</button>
                            </div>
                            <div id="templatePreviewContent"></div>
                            <button class="btn btn-primary" id="templateApplyBtn" onclick="applyTemplate()" style="margin-top:1rem;">Apply This Template</button>
                        </div>
                    </div>

                    <style>
                    .template-filter-btn {
                        background: #f0ebe4;
                        color: #5E503F;
                        border: none;
                        border-radius: 20px;
                        padding: 6px 16px;
                        font-size: 0.82rem;
                        cursor: pointer;
                        transition: all 0.2s ease;
                    }
                    .template-filter-btn:hover {
                        background: #e0dbd2;
                    }
                    .template-filter-btn.active {
                        background: #22333B;
                        color: white;
                    }
                    .template-card {
                        border: 1px solid #e0dbd2;
                        border-radius: 8px;
                        padding: 1rem;
                        background: #faf8f5;
                        cursor: pointer;
                        transition: all 0.2s ease;
                    }
                    .template-card:hover {
                        border-color: #D4A537;
                        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
                    }
                    .template-card-tag {
                        display: inline-block;
                        background: #e0dbd2;
                        color: #5E503F;
                        border-radius: 12px;
                        padding: 4px 10px;
                        font-size: 0.7rem;
                        margin-bottom: 0.5rem;
                        margin-right: 0.25rem;
                    }
                    .template-pill {
                        display: inline-block;
                        background: #f0ebe4;
                        color: #5E503F;
                        border-radius: 12px;
                        padding: 4px 10px;
                        font-size: 0.75rem;
                        margin: 2px;
                    }
                    </style>

                    <div class="step-actions-bar">
                        <button class="btn btn-clear" onclick="clearStep(1)">Clear This Step</button>
                        <button class="btn btn-clear-all" onclick="clearEntirePlan()">Clear Entire Plan</button>
                    </div>
                    <div class="button-group">
                        <button class="btn btn-save" onclick="saveAndConfirm(this)">Save Progress</button>
                        <button class="btn btn-primary" onclick="stepNext()">Next</button>
                    </div>
                </div>

                <!-- STEP 2: Vision & Mission -->
                <div class="step-content" data-step="2">
                    <div class="step-actions-bar">
                        <button class="btn btn-clear" onclick="clearStep(2)">Clear This Step</button>
                    </div>
                    <h1 class="step-title">Vision & Mission</h1>
                    <div class="section-purpose">
                        Your vision describes the future you're building. Your mission describes why you exist and how you'll get there. Together they give your district purpose and direction that resonates with every classroom.
                    </div>

                    <div class="guided-steps">

                        <!-- GUIDED STEP 1: Learn & Prepare -->
                        <div class="guided-step" id="gs-2-1">
                            <div class="guided-step-header" onclick="toggleGuidedStep(this)">
                                <div class="guided-step-number">1</div>
                                <h3>Learn & Prepare</h3>
                                <span class="substep-status status-todo" id="gs-2-1-status">To Do</span>
                                <svg class="guided-step-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><polyline points="6 9 12 15 18 9"/></svg>
                            </div>
                            <div class="guided-step-body">
                                <p class="substep-desc">Review these resources before you start. Great vision and mission statements don't happen in a vacuum. Study examples, download workshop materials, and prepare your team.</p>
                                <div class="doc-download-grid">
                                    <div class="doc-download-card"><span class="doc-type-badge pptx">PPTX</span><h4>Workshop Facilitation Slides</h4><p>Ready-to-present slides for running a vision and mission workshop.</p><button class="btn btn-download" onclick="generateVisionWorkshopPPTX(planState)">Download PPTX</button></div>
                                    <div class="doc-download-card"><span class="doc-type-badge docx">DOCX</span><h4>Stakeholder Survey Template</h4><p>Editable survey for gathering community input.</p><button class="btn btn-download" onclick="generateStakeholderSurveyDOCX(planState,'vision-mission')">Download DOCX</button></div>
                                    <div class="doc-download-card"><span class="doc-type-badge docx">DOCX</span><h4>Focus Group Discussion Guide</h4><p>Structured facilitation guide for focus groups.</p><button class="btn btn-download" onclick="generateFocusGroupGuideDOCX(planState)">Download DOCX</button></div>
                                    <div class="doc-download-card"><span class="doc-type-badge pptx">PPTX</span><h4>Board Presentation</h4><p>Present your vision and mission to the school board.</p><button class="btn btn-download" onclick="generateBoardVisionPPTX(planState)">Download PPTX</button></div>
                                    <div class="doc-download-card" style="border:2px solid var(--pop-teal);"><span class="doc-type-badge pdf">PDF</span><h4>Stakeholder Engagement Playbook</h4><p>Complete guide: who to engage, when, and how at every stage.</p><button class="btn btn-download" onclick="generateStakeholderEngagementGuidePDF(planState)">Download PDF</button></div>
                                </div>
                                <div style="margin-top:1rem; text-align:right;">
                                    <button class="btn btn-action" onclick="markGuidedStepDone('2','1')">I've reviewed the resources</button>
                                </div>
                            </div>
                        </div>

                        <!-- GUIDED STEP 2: Gather Stakeholder Input -->
                        <div class="guided-step collapsed" id="gs-2-2">
                            <div class="guided-step-header" onclick="toggleGuidedStep(this)">
                                <div class="guided-step-number">2</div>
                                <h3>Gather Stakeholder Input</h3>
                                <span class="substep-status status-todo" id="gs-2-2-status">To Do</span>
                                <svg class="guided-step-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><polyline points="6 9 12 15 18 9"/></svg>
                            </div>
                            <div class="guided-step-body">
                                <p class="substep-desc">Vision and mission should be shaped by your community. Select which stakeholder groups to engage and generate surveys or focus group guides.</p>
                                <div class="engagement-panel" style="margin:0; border:none; padding:0; background:transparent;">
                                    <div class="engagement-checklist">
                                        <label><input type="checkbox" id="surveyStaff" checked> Staff/Teachers</label>
                                        <label><input type="checkbox" id="surveyFamilies" checked> Families/Parents</label>
                                        <label><input type="checkbox" id="surveyStudents"> Students (Secondary)</label>
                                        <label><input type="checkbox" id="surveyCommunity"> Community Members</label>
                                        <label><input type="checkbox" id="surveyBoard"> Board Members</label>
                                    </div>
                                    <div class="engagement-actions">
                                        <button class="btn btn-action" onclick="generateVisionSurvey()">Generate Stakeholder Survey</button>
                                        <button class="btn btn-action" onclick="generateFocusGroupGuide('vision-mission')">Generate Focus Group Guide</button>
                                    </div>
                                    <div id="visionSurveyOutput" class="toolkit-output-area"></div>
                                    <div id="focusGroupGuideOutput" class="toolkit-output-area"></div>
                                </div>
                                <div style="margin-top:1rem; text-align:right;">
                                    <button class="btn btn-action" onclick="markGuidedStepDone('2','2')">Stakeholder engagement planned</button>
                                </div>
                            </div>
                        </div>

                        <!-- GUIDED STEP 2.5: Portrait of a Graduate -->
                        <div class="guided-step collapsed" id="gs-2-portrait">
                            <div class="guided-step-header" onclick="toggleGuidedStep(this)">
                                <div class="guided-step-number" style="background:linear-gradient(135deg,#D4A537,#e8b84a);">★</div>
                                <h3>Portrait of a Graduate</h3>
                                <span class="substep-status status-todo" id="gs-2-portrait-status">Optional</span>
                                <svg class="guided-step-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><polyline points="6 9 12 15 18 9"/></svg>
                            </div>
                            <div class="guided-step-body">
                                <p class="substep-desc">Define what your ideal graduate looks like. Based on the Battelle for Kids framework, the Portrait of a Graduate captures the competencies, skills, and dispositions your community wants every student to develop. This feeds directly into your vision, mission, and strategic goals.</p>
                                
                                <div style="padding:1rem;background:linear-gradient(135deg,#f7f5f0,#fff);border:1px solid #e0d8cf;border-radius:10px;margin-bottom:1.5rem;">
                                    <h5 style="font-family:'Plus Jakarta Sans',sans-serif;font-size:0.85rem;font-weight:700;color:#D4A537;margin:0 0 0.5rem 0;text-transform:uppercase;letter-spacing:0.5px;">Battelle for Kids Framework</h5>
                                    <p style="font-size:0.82rem;color:#5E503F;margin:0;">Common categories include: Critical Thinking, Communication, Collaboration, Creativity, Character, Citizenship, and Content Mastery. Customize these to reflect your community's priorities.</p>
                                </div>

                                <div class="portrait-builder" id="portraitBuilder">
                                    <h4 style="font-family:'Plus Jakarta Sans',sans-serif;font-size:0.95rem;font-weight:700;color:#22333B;margin:0 0 1rem 0;">Graduate Attributes</h4>
                                    
                                    <div id="portraitAttributes" style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;"></div>
                                    
                                    <div style="margin-top:1rem;">
                                        <button class="btn btn-ai" onclick="renderPortraitDefaults()">Load Default Attributes</button>
                                        <button class="btn btn-secondary" onclick="addCustomAttribute()" style="margin-left:0.5rem;">+ Add Custom</button>
                                    </div>
                                    
                                    <div id="customAttributeForm" style="display:none;margin-top:1rem;padding:1rem;background:#faf8f5;border-radius:8px;border:1px solid #e0d8cf;">
                                        <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;">
                                            <div>
                                                <label style="font-size:0.82rem;font-weight:600;color:#5E503F;">Attribute Name</label>
                                                <input type="text" id="customAttrName" placeholder="e.g., Digital Literacy" style="width:100%;padding:8px 12px;border:1px solid #e0d8cf;border-radius:6px;font-family:Inter,sans-serif;font-size:0.85rem;margin-top:4px;">
                                            </div>
                                            <div>
                                                <label style="font-size:0.82rem;font-weight:600;color:#5E503F;">Category</label>
                                                <select id="customAttrCategory" style="width:100%;padding:8px 12px;border:1px solid #e0d8cf;border-radius:6px;font-family:Inter,sans-serif;font-size:0.85rem;margin-top:4px;">
                                                    <option value="cognitive">Cognitive</option>
                                                    <option value="personal">Personal</option>
                                                    <option value="interpersonal">Interpersonal</option>
                                                    <option value="civic">Civic</option>
                                                </select>
                                            </div>
                                        </div>
                                        <div style="margin-top:0.75rem;">
                                            <label style="font-size:0.82rem;font-weight:600;color:#5E503F;">Description</label>
                                            <textarea id="customAttrDesc" placeholder="What does this look like in a graduate?" style="width:100%;padding:8px 12px;border:1px solid #e0d8cf;border-radius:6px;font-family:Inter,sans-serif;font-size:0.85rem;margin-top:4px;height:60px;resize:vertical;"></textarea>
                                        </div>
                                        <div style="margin-top:0.75rem;display:flex;gap:0.5rem;">
                                            <button class="btn btn-primary" onclick="saveCustomAttribute()">Add Attribute</button>
                                            <button class="btn btn-clear" onclick="document.getElementById('customAttributeForm').style.display='none'">Cancel</button>
                                        </div>
                                    </div>
                                </div>
                                
                                <div id="portraitSummary" style="display:none;margin-top:1.5rem;padding:1.5rem;background:linear-gradient(135deg,#22333B,#2d4a5a);border-radius:12px;text-align:center;">
                                    <h4 style="font-family:'Source Serif Pro',serif;color:#fff;margin:0 0 0.25rem 0;">Our Portrait of a Graduate</h4>
                                    <p style="color:rgba(255,255,255,0.7);font-size:0.82rem;margin:0 0 1.25rem 0;">Selected attributes that define your ideal graduate</p>
                                    <div id="portraitVisual" style="display:flex;flex-wrap:wrap;justify-content:center;gap:0.75rem;"></div>
                                </div>
                                
                                <div style="margin-top:1.5rem;text-align:right;">
                                    <button class="btn btn-save" onclick="savePortraitData()">Save Portrait</button>
                                </div>
                            </div>
                        </div>

                        <!-- GUIDED STEP 3: Draft Your Vision & Mission -->
                        <div class="guided-step collapsed" id="gs-2-3">
                            <div class="guided-step-header" onclick="toggleGuidedStep(this)">
                                <div class="guided-step-number">3</div>
                                <h3>Draft Your Vision & Mission</h3>
                                <span class="substep-status status-todo" id="gs-2-3-status">To Do</span>
                                <svg class="guided-step-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><polyline points="6 9 12 15 18 9"/></svg>
                            </div>
                            <div class="guided-step-body">
                                <p class="substep-desc">Select themes that resonate, then let AI help you craft a polished statement. Use the feedback area below to record what you heard from stakeholders.</p>

                                <h2 style="font-family: 'Source Serif Pro', serif; font-size: 1.25rem; color: #22333B; margin-top: 0.5rem; margin-bottom: 0.75rem;">Vision Statement</h2>
                                <div class="counter-bar">Selected: <span id="visionCounter">0</span> concepts</div>
                                <div class="vision-mission-grid">
                                    <label class="selection-card"><input type="checkbox" data-type="vision" data-value="equity"><div class="selection-card-inner"><div class="selection-card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><path d="M8 14s1.5 2 4 2 4-2 4-2"></path><line x1="9" y1="9" x2="9" y2="9"></line><line x1="15" y1="9" x2="15" y2="9"></line></svg></div><p class="selection-card-title">Every Student</p></div></label>
                                    <label class="selection-card"><input type="checkbox" data-type="vision" data-value="thriving"><div class="selection-card-inner"><div class="selection-card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg></div><p class="selection-card-title">Thriving</p></div></label>
                                    <label class="selection-card"><input type="checkbox" data-type="vision" data-value="empowered"><div class="selection-card-inner"><div class="selection-card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"></path></svg></div><p class="selection-card-title">Empowered</p></div></label>
                                    <label class="selection-card"><input type="checkbox" data-type="vision" data-value="future-ready"><div class="selection-card-inner"><div class="selection-card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="1"></circle><path d="M12 1v6m0 6v6"></path><path d="M4.22 4.22l4.24 4.24m5.08 5.08l4.24 4.24"></path><path d="M1 12h6m6 0h6"></path><path d="M4.22 19.78l4.24-4.24m5.08-5.08l4.24-4.24"></path></svg></div><p class="selection-card-title">Future-Ready</p></div></label>
                                    <label class="selection-card"><input type="checkbox" data-type="vision" data-value="healthy"><div class="selection-card-inner"><div class="selection-card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg></div><p class="selection-card-title">Healthy</p></div></label>
                                    <label class="selection-card"><input type="checkbox" data-type="vision" data-value="connected"><div class="selection-card-inner"><div class="selection-card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"></circle><path d="M21 21l-4.35-4.35"></path></svg></div><p class="selection-card-title">Connected</p></div></label>
                                    <label class="selection-card"><input type="checkbox" data-type="vision" data-value="innovative"><div class="selection-card-inner"><div class="selection-card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="1"></circle><path d="M12 1v6m8-6-4.24 4.24m0 5.08L20 20M1 12h6m6 0h6"></path></svg></div><p class="selection-card-title">Innovative</p></div></label>
                                    <label class="selection-card"><input type="checkbox" data-type="vision" data-value="inclusive"><div class="selection-card-inner"><div class="selection-card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg></div><p class="selection-card-title">Inclusive</p></div></label>
                                </div>
                                <div class="custom-input-section">
                                    <label>Write/Edit Your Own Vision Concept</label>
                                    <textarea id="customVision" placeholder="Describe a vision concept that matters to your district..." oninput="combineVisionStatements()"></textarea>
                                    <button class="btn btn-action" onclick="addCustomVision()">Add Custom Concept</button>
                                </div>
                                <div id="aiVisionOutput" class="ai-response-area"></div>

                                <div class="section-divider"></div>

                                <h2 style="font-family: 'Source Serif Pro', serif; font-size: 1.25rem; color: #22333B; margin-top: 0.5rem; margin-bottom: 0.75rem;">Mission Statement</h2>
                                <div class="counter-bar">Selected: <span id="missionCounter">0</span> elements</div>
                                <div class="vision-mission-grid">
                                    <label class="selection-card"><input type="checkbox" data-type="mission" data-value="excellence"><div class="selection-card-inner"><div class="selection-card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"></path></svg></div><p class="selection-card-title">Excellence</p></div></label>
                                    <label class="selection-card"><input type="checkbox" data-type="mission" data-value="access"><div class="selection-card-inner"><div class="selection-card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 3H9a6 6 0 0 0-6 6v10a6 6 0 0 0 6 6h6a6 6 0 0 0 6-6V9a6 6 0 0 0-6-6z"></path><circle cx="12" cy="12" r="3"></circle></svg></div><p class="selection-card-title">Access</p></div></label>
                                    <label class="selection-card"><input type="checkbox" data-type="mission" data-value="collaboration"><div class="selection-card-inner"><div class="selection-card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg></div><p class="selection-card-title">Collaboration</p></div></label>
                                    <label class="selection-card"><input type="checkbox" data-type="mission" data-value="accountability"><div class="selection-card-inner"><div class="selection-card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 11l3 3L22 4"></path><path d="M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0z"></path></svg></div><p class="selection-card-title">Accountability</p></div></label>
                                    <label class="selection-card"><input type="checkbox" data-type="mission" data-value="equity"><div class="selection-card-inner"><div class="selection-card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12a9 9 0 1 1 18 0 9 9 0 0 1-18 0"></path><circle cx="12" cy="12" r="3"></circle></svg></div><p class="selection-card-title">Equity</p></div></label>
                                    <label class="selection-card"><input type="checkbox" data-type="mission" data-value="growth"><div class="selection-card-inner"><div class="selection-card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 17"></polyline><polyline points="17 6 23 6 23 12"></polyline></svg></div><p class="selection-card-title">Growth</p></div></label>
                                    <label class="selection-card"><input type="checkbox" data-type="mission" data-value="innovation"><div class="selection-card-inner"><div class="selection-card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg></div><p class="selection-card-title">Innovation</p></div></label>
                                    <label class="selection-card"><input type="checkbox" data-type="mission" data-value="sustainability"><div class="selection-card-inner"><div class="selection-card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"></path><path d="M12 6v6l5 3"></path></svg></div><p class="selection-card-title">Sustainability</p></div></label>
                                </div>
                                <div class="custom-input-section">
                                    <label>Write/Edit Your Own Mission Element</label>
                                    <textarea id="customMission" placeholder="Describe a mission element that defines how you work..." oninput="combineMissionStatements()"></textarea>
                                    <button class="btn btn-action" onclick="addCustomMission()">Add Custom Element</button>
                                </div>
                                <div id="aiMissionOutput" class="ai-response-area"></div>

                                <!-- Stakeholder Feedback Entry -->
                                <div class="section-divider"></div>
                                <div class="feedback-entry">
                                    <h4><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16" style="vertical-align:-3px;margin-right:6px;"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>Stakeholder Feedback</h4>
                                    <p style="font-size:0.82rem;color:var(--brown);margin:0 0 10px 0;">Record key themes, quotes, and feedback from your stakeholder engagement. The grader checks whether you incorporated this input.</p>
                                    <div style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:8px;">
                                        <span class="feedback-tag">Staff</span>
                                        <span class="feedback-tag">Families</span>
                                        <span class="feedback-tag">Students</span>
                                        <span class="feedback-tag">Community</span>
                                        <span class="feedback-tag">Board</span>
                                    </div>
                                    <textarea id="stakeholderFeedback2" placeholder="What did stakeholders say? Key themes, direct quotes, common requests..." oninput="saveStakeholderFeedback(2, this.value)"></textarea>
                                </div>
                            </div>
                        </div>

                        <!-- GUIDED STEP 4: Finalize, Grade & Report -->
                        <div class="guided-step collapsed" id="gs-2-4">
                            <div class="guided-step-header" onclick="toggleGuidedStep(this)">
                                <div class="guided-step-number">4</div>
                                <h3>Finalize, Grade & Report</h3>
                                <span class="substep-status status-todo" id="gs-2-4-status">To Do</span>
                                <svg class="guided-step-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><polyline points="6 9 12 15 18 9"/></svg>
                            </div>
                            <div class="guided-step-body">
                                <p class="substep-desc">Grade your work, review improvement tips, and download your Vision & Mission section report.</p>

                                <!-- SECTION GRADER -->
                                <div class="section-grader" id="grader-stage-2">
                                    <div class="section-grader-top">
                                        <div class="section-grade-circle" id="grade-circle-2">--</div>
                                        <div class="section-grader-info">
                                            <h3>Vision & Mission Grade</h3>
                                            <p id="grade-summary-2">Complete your vision and mission to receive a grade.</p>
                                        </div>
                                    </div>
                                    <div class="section-grader-criteria" id="grade-criteria-2">
                                        <div class="grader-criterion"><span class="criterion-dot" id="crit-2-1"></span>Vision is concise (under 30 words)</div>
                                        <div class="grader-criterion"><span class="criterion-dot" id="crit-2-2"></span>Vision is aspirational and forward-looking</div>
                                        <div class="grader-criterion"><span class="criterion-dot" id="crit-2-3"></span>Vision centers student outcomes</div>
                                        <div class="grader-criterion"><span class="criterion-dot" id="crit-2-4"></span>Mission states purpose and approach</div>
                                        <div class="grader-criterion"><span class="criterion-dot" id="crit-2-5"></span>Mission is community-understandable</div>
                                        <div class="grader-criterion"><span class="criterion-dot" id="crit-2-6"></span>Vision and mission are aligned</div>
                                        <div class="grader-criterion"><span class="criterion-dot" id="crit-2-7"></span>Stakeholder feedback was recorded</div>
                                        <div class="grader-criterion"><span class="criterion-dot" id="crit-2-8"></span>Stakeholder input reflected in statements</div>
                                    </div>
                                    <button class="grader-btn" onclick="gradeSection(2)">Grade My Work</button>
                                    <div class="grader-tips" id="grade-tips-2">
                                        <h4>How to Improve</h4>
                                        <ul id="grade-tips-list-2"></ul>
                                    </div>
                                </div>

                                <!-- STANDALONE SECTION REPORT -->
                                <div class="section-report-download" style="margin-top:1.5rem;">
                                    <div class="report-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="24" height="24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg></div>
                                    <div class="report-info">
                                        <h4>Vision & Mission Report</h4>
                                        <p>Complete analysis with clarity scores and alignment checks</p>
                                    </div>
                                    <button class="btn-report" onclick="generateVisionMissionPDF(planState)">Download PDF</button>
                                </div>
                            </div>
                        </div>

                    </div><!-- /.guided-steps -->

                    <div class="step-actions-bar">
                        <button class="btn btn-clear" onclick="clearStep(2)">Clear This Step</button>
                    </div>
                    <div class="button-group">
                        <button class="btn btn-save" onclick="saveAndConfirm(this)">Save Progress</button>
                        <button class="btn btn-secondary" onclick="stepPrev()">Previous</button>
                        <button class="btn btn-primary" onclick="stepNext()">Next</button>
                    </div>
                </div>

                <!-- STEP 3: Core Values -->
                <div class="step-content" data-step="3">
                    <div class="step-actions-bar"><button class="btn btn-clear" onclick="clearStep(3)">Clear This Step</button></div>
                    <h1 class="step-title">Core Values</h1>
                    <div class="section-purpose">Your values define how you'll operate every day. They're the non-negotiables that guide decisions, shape culture, and show students and families what you really stand for.</div>

                    <div class="guided-steps">

                        <!-- GUIDED STEP 1: Learn & Prepare -->
                        <div class="guided-step" id="gs-3-1">
                            <div class="guided-step-header" onclick="toggleGuidedStep(this)">
                                <div class="guided-step-number">1</div>
                                <h3>Learn & Prepare</h3>
                                <span class="substep-status status-todo" id="gs-3-1-status">To Do</span>
                                <svg class="guided-step-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><polyline points="6 9 12 15 18 9"/></svg>
                            </div>
                            <div class="guided-step-body">
                                <p class="substep-desc">Download workshop materials and review examples of strong core values before engaging your community.</p>
                                <div class="doc-download-grid">
                                    <div class="doc-download-card"><span class="doc-type-badge pptx">PPTX</span><h4>Values Workshop Slides</h4><p>Ready-to-present slides for staff values workshop.</p><button class="btn btn-download" onclick="generateValuesWorkshopPPTX(planState)">Download PPTX</button></div>
                                    <div class="doc-download-card"><span class="doc-type-badge docx">DOCX</span><h4>Values-to-Behaviors Guide</h4><p>Operational guide for living your district values.</p><button class="btn btn-download" onclick="generateValuesBehaviorsDOCX(planState)">Download DOCX</button></div>
                                    <div class="doc-download-card"><span class="doc-type-badge docx">DOCX</span><h4>Staff Communication</h4><p>Letter and talking points for introducing values to staff.</p><button class="btn btn-download" onclick="generateStaffCommsDOCX(planState)">Download DOCX</button></div>
                                    <div class="doc-download-card"><span class="doc-type-badge pptx">PPTX</span><h4>Board Presentation</h4><p>Present core values to the school board.</p><button class="btn btn-download" onclick="generateBoardValuesPPTX(planState)">Download PPTX</button></div>
                                </div>
                                <div style="margin-top:1rem; text-align:right;">
                                    <button class="btn btn-action" onclick="markGuidedStepDone('3','1')">I've reviewed the resources</button>
                                </div>
                            </div>
                        </div>

                        <!-- GUIDED STEP 2: Gather Stakeholder Input -->
                        <div class="guided-step collapsed" id="gs-3-2">
                            <div class="guided-step-header" onclick="toggleGuidedStep(this)">
                                <div class="guided-step-number">2</div>
                                <h3>Gather Stakeholder Input</h3>
                                <span class="substep-status status-todo" id="gs-3-2-status">To Do</span>
                                <svg class="guided-step-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><polyline points="6 9 12 15 18 9"/></svg>
                            </div>
                            <div class="guided-step-body">
                                <p class="substep-desc">Core values should reflect what your whole community believes in. Survey staff, families, and students on what matters most.</p>
                                <div class="engagement-checklist">
                                    <label class="engagement-check-label"><input type="checkbox" id="surveyStaffValues" /> Staff values survey sent</label>
                                    <label class="engagement-check-label"><input type="checkbox" id="surveyFamilyValues" /> Family values survey sent</label>
                                    <label class="engagement-check-label"><input type="checkbox" id="surveyStudentValues" /> Student values survey sent</label>
                                </div>
                                <div class="engagement-actions">
                                    <button class="btn btn-action" onclick="generateSurvey('values')">Generate Values Survey</button>
                                    <button class="btn btn-action" onclick="generateFocusGroupGuide('values')">Generate Focus Group Guide</button>
                                </div>
                                <div id="valuesSurveyOutput" class="toolkit-output-area"></div>
                                <div style="margin-top:1rem; text-align:right;">
                                    <button class="btn btn-action" onclick="markGuidedStepDone('3','2')">Stakeholder engagement planned</button>
                                </div>
                            </div>
                        </div>

                        <!-- GUIDED STEP 3: Select & Define Values -->
                        <div class="guided-step collapsed" id="gs-3-3">
                            <div class="guided-step-header" onclick="toggleGuidedStep(this)">
                                <div class="guided-step-number">3</div>
                                <h3>Select & Define Your Values</h3>
                                <span class="substep-status status-todo" id="gs-3-3-status">To Do</span>
                                <svg class="guided-step-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><polyline points="6 9 12 15 18 9"/></svg>
                            </div>
                            <div class="guided-step-body">
                                <p class="substep-desc">Select 4 to 6 core values that define how your district operates every day. Use the AI helper to cluster themes or generate behavioral definitions.</p>
                                <div id="coreValuesContainer"></div>
                                <div class="counter-bar" style="margin-top:1.5rem;">Selected: <span id="valuesCounter">0</span> values</div>
                                <div id="aiValuesClusterOutput" class="ai-response-area"></div>
                                <div id="aiValueDefinitionsOutput" class="ai-response-area"></div>

                                <div class="section-divider"></div>
                                <div class="feedback-entry">
                                    <h4><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16" style="vertical-align:-3px;margin-right:6px;"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>Stakeholder Feedback</h4>
                                    <p style="font-size:0.82rem;color:var(--brown);margin:0 0 10px 0;">Record key themes from your stakeholder engagement about values. The grader checks whether you incorporated this input.</p>
                                    <textarea id="stakeholderFeedback3" placeholder="What values did stakeholders say matter most? Key themes, common words, recurring priorities..." oninput="saveStakeholderFeedback(3, this.value)"></textarea>
                                </div>
                            </div>
                        </div>

                        <!-- GUIDED STEP 4: Finalize, Grade & Report -->
                        <div class="guided-step collapsed" id="gs-3-4">
                            <div class="guided-step-header" onclick="toggleGuidedStep(this)">
                                <div class="guided-step-number">4</div>
                                <h3>Finalize, Grade & Report</h3>
                                <span class="substep-status status-todo" id="gs-3-4-status">To Do</span>
                                <svg class="guided-step-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><polyline points="6 9 12 15 18 9"/></svg>
                            </div>
                            <div class="guided-step-body">
                                <p class="substep-desc">Grade your core values, review improvement tips, and download your section report.</p>
                                <div class="section-grader" id="grader-stage-3">
                                    <div class="section-grader-top">
                                        <div class="section-grade-circle" id="grade-circle-3">--</div>
                                        <div class="section-grader-info">
                                            <h3>Core Values Grade</h3>
                                            <p id="grade-summary-3">Select your values to receive a grade.</p>
                                        </div>
                                    </div>
                                    <div class="section-grader-criteria" id="grade-criteria-3">
                                        <div class="grader-criterion"><span class="criterion-dot" id="crit-3-1"></span>4-6 core values selected</div>
                                        <div class="grader-criterion"><span class="criterion-dot" id="crit-3-2"></span>Values are distinct and non-overlapping</div>
                                        <div class="grader-criterion"><span class="criterion-dot" id="crit-3-3"></span>Values are actionable, not just symbolic</div>
                                        <div class="grader-criterion"><span class="criterion-dot" id="crit-3-4"></span>Each value has behavioral indicators</div>
                                        <div class="grader-criterion"><span class="criterion-dot" id="crit-3-5"></span>Stakeholder feedback was recorded</div>
                                        <div class="grader-criterion"><span class="criterion-dot" id="crit-3-6"></span>Stakeholder input reflected in value selections</div>
                                    </div>
                                    <button class="grader-btn" onclick="gradeSection(3)">Grade My Work</button>
                                    <div class="grader-tips" id="grade-tips-3"><h4>How to Improve</h4><ul id="grade-tips-list-3"></ul></div>
                                </div>
                                <div class="section-report-download" style="margin-top:1.5rem;">
                                    <div class="report-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="24" height="24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg></div>
                                    <div class="report-info"><h4>Core Values Report</h4><p>Behavioral definitions and alignment analysis</p></div>
                                    <button class="btn-report" onclick="generateValuesReportPDF(planState)">Download PDF</button>
                                </div>
                            </div>
                        </div>

                    </div><!-- /.guided-steps -->

                    <div class="step-actions-bar"><button class="btn btn-clear" onclick="clearStep(3)">Clear This Step</button></div>
                    <div class="button-group">
                        <button class="btn btn-save" onclick="saveAndConfirm(this)">Save Progress</button>
                        <button class="btn btn-secondary" onclick="stepPrev()">Previous</button>
                        <button class="btn btn-primary" onclick="stepNext()">Next</button>
                    </div>
                </div>

                <!-- STEP 4: Competencies -->
                <div class="step-content" data-step="4">
                    <div class="step-actions-bar"><button class="btn btn-clear" onclick="clearStep(4)">Clear This Step</button></div>
                    <h1 class="step-title">Competencies</h1>
                    <div class="section-purpose">Competencies are the capabilities your team needs to execute your strategy. Pick two from each category to build a well-rounded set of competencies.</div>

                    <div class="guided-steps">

                        <!-- GUIDED STEP 1: Learn & Prepare -->
                        <div class="guided-step" id="gs-4-1">
                            <div class="guided-step-header" onclick="toggleGuidedStep(this)">
                                <div class="guided-step-number">1</div>
                                <h3>Learn & Prepare</h3>
                                <span class="substep-status status-todo" id="gs-4-1-status">To Do</span>
                                <svg class="guided-step-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><polyline points="6 9 12 15 18 9"/></svg>
                            </div>
                            <div class="guided-step-body">
                                <p class="substep-desc">Download templates and review competency frameworks before building yours. A strong competency map connects what your people can do to what your strategy demands.</p>
                                <div class="doc-download-grid">
                                    <div class="doc-download-card"><span class="doc-type-badge docx">DOCX</span><h4>Competency Map</h4><p>Visual mapping of competencies to strategy areas.</p><button class="btn btn-download" onclick="generateCompetencyMapDOCX(planState)">Download DOCX</button></div>
                                    <div class="doc-download-card"><span class="doc-type-badge docx">DOCX</span><h4>Leadership Self-Assessment</h4><p>Tool for leaders to assess capability readiness.</p><button class="btn btn-download" onclick="generateLeadershipAssessmentDOCX(planState)">Download DOCX</button></div>
                                </div>
                                <div style="margin-top:1rem; text-align:right;">
                                    <button class="btn btn-action" onclick="markGuidedStepDone('4','1')">I've reviewed the resources</button>
                                </div>
                            </div>
                        </div>

                        <!-- GUIDED STEP 2: Build Your Framework -->
                        <div class="guided-step collapsed" id="gs-4-2">
                            <div class="guided-step-header" onclick="toggleGuidedStep(this)">
                                <div class="guided-step-number">2</div>
                                <h3>Build Your Competency Framework</h3>
                                <span class="substep-status status-todo" id="gs-4-2-status">To Do</span>
                                <svg class="guided-step-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><polyline points="6 9 12 15 18 9"/></svg>
                            </div>
                            <div class="guided-step-body">
                                <p class="substep-desc">Select competencies from each category. Use the AI helper to suggest competencies based on your vision and values, or to assess capability gaps.</p>
                                <div id="competenciesContainer"></div>
                                <div id="aiCompetenciesOutput" class="ai-response-area"></div>
                                <div id="aiCapabilityGapsOutput" class="ai-response-area"></div>
                            </div>
                        </div>

                        <!-- GUIDED STEP 3: Finalize, Grade & Report -->
                        <div class="guided-step collapsed" id="gs-4-3">
                            <div class="guided-step-header" onclick="toggleGuidedStep(this)">
                                <div class="guided-step-number">3</div>
                                <h3>Finalize, Grade & Report</h3>
                                <span class="substep-status status-todo" id="gs-4-3-status">To Do</span>
                                <svg class="guided-step-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><polyline points="6 9 12 15 18 9"/></svg>
                            </div>
                            <div class="guided-step-body">
                                <p class="substep-desc">Grade your competency framework, review improvement tips, and download your section report.</p>
                                <div class="section-grader" id="grader-stage-4">
                                    <div class="section-grader-top">
                                        <div class="section-grade-circle" id="grade-circle-4">--</div>
                                        <div class="section-grader-info">
                                            <h3>Competencies Grade</h3>
                                            <p id="grade-summary-4">Select your competencies to receive a grade.</p>
                                        </div>
                                    </div>
                                    <div class="section-grader-criteria" id="grade-criteria-4">
                                        <div class="grader-criterion"><span class="criterion-dot" id="crit-4-1"></span>Competencies selected from each category</div>
                                        <div class="grader-criterion"><span class="criterion-dot" id="crit-4-2"></span>Core vs supporting competencies distinguished</div>
                                        <div class="grader-criterion"><span class="criterion-dot" id="crit-4-3"></span>Competencies aligned with vision and goals</div>
                                        <div class="grader-criterion"><span class="criterion-dot" id="crit-4-4"></span>Aligned with staffing, technology, and operations</div>
                                    </div>
                                    <button class="grader-btn" onclick="gradeSection(4)">Grade My Work</button>
                                    <div class="grader-tips" id="grade-tips-4"><h4>How to Improve</h4><ul id="grade-tips-list-4"></ul></div>
                                </div>
                                <div class="section-report-download" style="margin-top:1.5rem;">
                                    <div class="report-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="24" height="24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg></div>
                                    <div class="report-info"><h4>Competency Report</h4><p>Capability assessment with gap analysis</p></div>
                                    <button class="btn-report" onclick="generateCompetencyReportPDF(planState)">Download PDF</button>
                                </div>
                            </div>
                        </div>

                    </div><!-- /.guided-steps -->

                    <div class="step-actions-bar" style="margin-top:2.5rem;"><button class="btn btn-clear" onclick="clearStep(4)">Clear This Step</button></div>
                    <div class="button-group">
                        <button class="btn btn-save" onclick="saveAndConfirm(this)">Save Progress</button>
                        <button class="btn btn-secondary" onclick="stepPrev()">Previous</button>
                        <button class="btn btn-primary" onclick="stepNext()">Next</button>
                    </div>
                </div>

                <!-- STEP 5: Strategic Domains -->
                <div class="step-content" data-step="5">
                    <div class="step-actions-bar"><button class="btn btn-clear" onclick="clearStep(5)">Clear This Step</button></div>
                    <h1 class="step-title">Strategic Domains</h1>
                    <div class="section-purpose">Strategic domains are the big buckets of work where your district will focus over the next three to five years. They keep everyone aligned to what matters most.</div>

                    <div class="guided-steps">

                        <!-- GUIDED STEP 1: Learn & Prepare -->
                        <div class="guided-step" id="gs-5-1">
                            <div class="guided-step-header" onclick="toggleGuidedStep(this)">
                                <div class="guided-step-number">1</div>
                                <h3>Learn & Prepare</h3>
                                <span class="substep-status status-todo" id="gs-5-1-status">To Do</span>
                                <svg class="guided-step-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><polyline points="6 9 12 15 18 9"/></svg>
                            </div>
                            <div class="guided-step-body">
                                <p class="substep-desc">Download workshop materials and prioritization tools. Strategic domains should emerge from data and dialogue, not guesswork.</p>
                                <div class="doc-download-grid">
                                    <div class="doc-download-card"><span class="doc-type-badge pptx">PPTX</span><h4>Leadership Review Slides</h4><p>Present domains for leadership team discussion.</p><button class="btn btn-download" onclick="generateDomainsPPTX(planState)">Download PPTX</button></div>
                                    <div class="doc-download-card"><span class="doc-type-badge docx">DOCX</span><h4>Prioritization Matrix</h4><p>Worksheet for domain prioritization exercise.</p><button class="btn btn-download" onclick="generatePrioritizationMatrixDOCX(planState)">Download DOCX</button></div>
                                </div>
                                <div style="margin-top:1rem; text-align:right;">
                                    <button class="btn btn-action" onclick="markGuidedStepDone('5','1')">I've reviewed the resources</button>
                                </div>
                            </div>
                        </div>

                        <!-- GUIDED STEP 2: Engage Leadership -->
                        <div class="guided-step collapsed" id="gs-5-2">
                            <div class="guided-step-header" onclick="toggleGuidedStep(this)">
                                <div class="guided-step-number">2</div>
                                <h3>Engage Your Leadership Team</h3>
                                <span class="substep-status status-todo" id="gs-5-2-status">To Do</span>
                                <svg class="guided-step-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><polyline points="6 9 12 15 18 9"/></svg>
                            </div>
                            <div class="guided-step-body">
                                <p class="substep-desc">Strategic domains should be brainstormed with principals, department heads, and your board. Use the workshop guide to facilitate a domain prioritization session.</p>
                                <div class="engagement-checklist">
                                    <label class="engagement-check-label"><input type="checkbox" id="engageLeadersDomains" /> Leadership team workshop completed</label>
                                    <label class="engagement-check-label"><input type="checkbox" id="engageBoardDomains" /> Board input gathered</label>
                                    <label class="engagement-check-label"><input type="checkbox" id="engagePrincipalsDomains" /> Principal feedback collected</label>
                                </div>
                                <div class="engagement-actions">
                                    <button class="btn btn-action" onclick="generateFocusGroupGuide('domains')">Generate Workshop Guide</button>
                                </div>
                                <div id="domainWorkshopOutput" class="toolkit-output-area"></div>
                                <div style="margin-top:1rem; text-align:right;">
                                    <button class="btn btn-action" onclick="markGuidedStepDone('5','2')">Leadership engagement planned</button>
                                </div>
                            </div>
                        </div>

                        <!-- GUIDED STEP 3: Select & Define Domains -->
                        <div class="guided-step collapsed" id="gs-5-3">
                            <div class="guided-step-header" onclick="toggleGuidedStep(this)">
                                <div class="guided-step-number">3</div>
                                <h3>Select & Define Domains</h3>
                                <span class="substep-status status-todo" id="gs-5-3-status">To Do</span>
                                <svg class="guided-step-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><polyline points="6 9 12 15 18 9"/></svg>
                            </div>
                            <div class="guided-step-body">
                                <p class="substep-desc">Select 4 to 5 strategic domains that represent your district's highest priorities. Use the AI helper to cluster themes or suggest professional domain names.</p>
                                <div id="domainsContainer"></div>
                                <div class="counter-bar" style="margin-top:1.5rem;">Selected: <span id="domainsCounter">0</span> domains</div>
                                <div id="aiDomainsOutput" class="ai-response-area"></div>
                                <div id="aiDomainNamesOutput" class="ai-response-area"></div>

                                <div class="section-divider"></div>
                                <div class="feedback-entry">
                                    <h4><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16" style="vertical-align:-3px;margin-right:6px;"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>Leadership Feedback</h4>
                                    <p style="font-size:0.82rem;color:var(--brown);margin:0 0 10px 0;">Record what your leadership team and board said about strategic priorities.</p>
                                    <textarea id="stakeholderFeedback5" placeholder="What priorities did leaders identify? What did the board emphasize? Where was there alignment or disagreement?" oninput="saveStakeholderFeedback(5, this.value)"></textarea>
                                </div>
                            </div>
                        </div>

                        <!-- GUIDED STEP 4: Finalize, Grade & Report -->
                        <div class="guided-step collapsed" id="gs-5-4">
                            <div class="guided-step-header" onclick="toggleGuidedStep(this)">
                                <div class="guided-step-number">4</div>
                                <h3>Finalize, Grade & Report</h3>
                                <span class="substep-status status-todo" id="gs-5-4-status">To Do</span>
                                <svg class="guided-step-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><polyline points="6 9 12 15 18 9"/></svg>
                            </div>
                            <div class="guided-step-body">
                                <p class="substep-desc">Grade your strategic domains, review improvement tips, and download your section report.</p>
                                <div class="section-grader" id="grader-stage-5">
                                    <div class="section-grader-top">
                                        <div class="section-grade-circle" id="grade-circle-5">--</div>
                                        <div class="section-grader-info">
                                            <h3>Strategic Domains Grade</h3>
                                            <p id="grade-summary-5">Select your domains to receive a grade.</p>
                                        </div>
                                    </div>
                                    <div class="section-grader-criteria" id="grade-criteria-5">
                                        <div class="grader-criterion"><span class="criterion-dot" id="crit-5-1"></span>4-6 domains selected</div>
                                        <div class="grader-criterion"><span class="criterion-dot" id="crit-5-2"></span>Domains are clearly distinct from each other</div>
                                        <div class="grader-criterion"><span class="criterion-dot" id="crit-5-3"></span>Domains cover key areas (academic, operational, culture)</div>
                                        <div class="grader-criterion"><span class="criterion-dot" id="crit-5-4"></span>Domains aligned with vision and mission</div>
                                        <div class="grader-criterion"><span class="criterion-dot" id="crit-5-5"></span>Leadership feedback was recorded</div>
                                    </div>
                                    <button class="grader-btn" onclick="gradeSection(5)">Grade My Work</button>
                                    <div class="grader-tips" id="grade-tips-5"><h4>How to Improve</h4><ul id="grade-tips-list-5"></ul></div>
                                </div>
                                <div class="section-report-download" style="margin-top:1.5rem;">
                                    <div class="report-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="24" height="24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg></div>
                                    <div class="report-info"><h4>Domains Analysis Report</h4><p>Domain analysis with alignment mapping</p></div>
                                    <button class="btn-report" onclick="generateDomainsReportPDF(planState)">Download PDF</button>
                                </div>
                            </div>
                        </div>

                    </div><!-- /.guided-steps -->

                    <div class="step-actions-bar"><button class="btn btn-clear" onclick="clearStep(5)">Clear This Step</button></div>
                    <div class="button-group">
                        <button class="btn btn-save" onclick="saveAndConfirm(this)">Save Progress</button>
                        <button class="btn btn-secondary" onclick="stepPrev()">Previous</button>
                        <button class="btn btn-primary" onclick="stepNext()">Next</button>
                    </div>
                </div>

                <!-- STEP 6: Strategic Goal Setting -->
                <div class="step-content" data-step="6">
                    <div class="step-actions-bar"><button class="btn btn-clear" onclick="clearStep(6)">Clear This Step</button></div>
                    <h1 class="step-title">Strategic Goal Setting</h1>
                    <div class="section-purpose">Good goals are specific, measurable, and tied to your domains. They show what success looks like and how you'll know you're winning.</div>

                    <div class="guided-steps">

                        <!-- GUIDED STEP 1: Learn & Prepare -->
                        <div class="guided-step" id="gs-6-1">
                            <div class="guided-step-header" onclick="toggleGuidedStep(this)">
                                <div class="guided-step-number">1</div>
                                <h3>Learn & Prepare</h3>
                                <span class="substep-status status-todo" id="gs-6-1-status">To Do</span>
                                <svg class="guided-step-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><polyline points="6 9 12 15 18 9"/></svg>
                            </div>
                            <div class="guided-step-body">
                                <p class="substep-desc">Download workshop materials and alignment tools. Strong goals are SMART: Specific, Measurable, Achievable, Relevant, and Time-bound.</p>
                                <div class="doc-download-grid">
                                    <div class="doc-download-card"><span class="doc-type-badge pptx">PPTX</span><h4>Staff Workshop Slides</h4><p>Workshop slides for goal-setting with teams.</p><button class="btn btn-download" onclick="generateGoalWorkshopPPTX(planState)">Download PPTX</button></div>
                                    <div class="doc-download-card"><span class="doc-type-badge docx">DOCX</span><h4>Goal Alignment Matrix</h4><p>Map goals to vision, domains, and metrics.</p><button class="btn btn-download" onclick="generateGoalAlignmentDOCX(planState)">Download DOCX</button></div>
                                    <div class="doc-download-card"><span class="doc-type-badge pptx">PPTX</span><h4>Board Presentation</h4><p>Present strategic goals for board approval.</p><button class="btn btn-download" onclick="generateBoardGoalsPPTX(planState)">Download PPTX</button></div>
                                </div>
                                <div style="margin-top:1rem; text-align:right;">
                                    <button class="btn btn-action" onclick="markGuidedStepDone('6','1')">I've reviewed the resources</button>
                                </div>
                            </div>
                        </div>

                        <!-- GUIDED STEP 2: Engage Staff & Community -->
                        <div class="guided-step collapsed" id="gs-6-2">
                            <div class="guided-step-header" onclick="toggleGuidedStep(this)">
                                <div class="guided-step-number">2</div>
                                <h3>Engage Staff & Community</h3>
                                <span class="substep-status status-todo" id="gs-6-2-status">To Do</span>
                                <svg class="guided-step-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><polyline points="6 9 12 15 18 9"/></svg>
                            </div>
                            <div class="guided-step-body">
                                <p class="substep-desc">Goals should be informed by the people who will implement them. Host goal-setting workshops by domain area with staff teams and community advisory groups.</p>
                                <div class="engagement-checklist">
                                    <label class="engagement-check-label"><input type="checkbox" id="engageStaffGoals" /> Staff goal-setting workshops completed</label>
                                    <label class="engagement-check-label"><input type="checkbox" id="engageCommunityGoals" /> Community advisory input gathered</label>
                                    <label class="engagement-check-label"><input type="checkbox" id="engageBoardGoals" /> Board review scheduled</label>
                                </div>
                                <div class="engagement-actions">
                                    <button class="btn btn-action" onclick="generateFocusGroupGuide('goals')">Generate Workshop Guide</button>
                                </div>
                                <div id="goalsWorkshopOutput" class="toolkit-output-area"></div>
                                <div style="margin-top:1rem; text-align:right;">
                                    <button class="btn btn-action" onclick="markGuidedStepDone('6','2')">Engagement planned</button>
                                </div>
                            </div>
                        </div>

                        <!-- GUIDED STEP 3: Upload Data & Set Goals -->
                        <div class="guided-step collapsed" id="gs-6-3">
                            <div class="guided-step-header" onclick="toggleGuidedStep(this)">
                                <div class="guided-step-number">3</div>
                                <h3>Upload Data & Set Goals</h3>
                                <span class="substep-status status-todo" id="gs-6-3-status">To Do</span>
                                <svg class="guided-step-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><polyline points="6 9 12 15 18 9"/></svg>
                            </div>
                            <div class="guided-step-body">
                                <p class="substep-desc">Upload your district data or enter it manually. We'll analyze trends and generate SMART goals, or select from suggested goals below.</p>

                                <!-- DATA UPLOAD SECTION -->
                                <div class="data-upload-section" id="dataUploadSection">
                                    <h2 style="font-family:'Source Serif Pro',serif;font-size:1.25rem;color:#22333B;margin:0.5rem 0 0.5rem 0;">Upload District Data</h2>
                                    <p style="font-size:0.88rem;color:#5E503F;margin-bottom:1rem;">Upload a CSV or Excel file with your district performance data. We'll analyze trends and auto-generate SMART goals.</p>
                                    <div class="data-upload-zone" id="dataUploadZone">
                                        <div class="upload-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="36" height="36"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg></div>
                                        <p><strong>Drag & drop</strong> your CSV or Excel file here, or <label for="dataFileInput" style="color:#00B4CC;cursor:pointer;text-decoration:underline;">browse files</label></p>
                                        <p style="font-size:0.8rem;color:#999;">Supports .csv, .xlsx, .xls files. Expected columns: Metric, Year, Value (or similar)</p>
                                        <input type="file" id="dataFileInput" accept=".csv,.xlsx,.xls" style="display:none;" onchange="handleDataUpload(this)" />
                                    </div>
                                    <div id="dataUploadPreview" style="display:none;"></div>
                                    <div style="margin-top:1rem;text-align:center;"><span style="color:#999;font-size:0.85rem;">-- or enter data manually --</span></div>
                                    <div id="manualDataEntry" style="margin-top:1rem;">
                                        <div id="manualMetricRows">
                                            <div class="manual-metric-row" style="display:flex;gap:0.5rem;margin-bottom:0.5rem;flex-wrap:wrap;">
                                                <input type="text" placeholder="Metric name (e.g., Graduation Rate)" class="manual-metric-name" style="flex:2;min-width:180px;padding:0.5rem 0.7rem;border:1px solid #ddd;border-radius:4px;font-size:0.85rem;font-family:Inter,sans-serif;" />
                                                <input type="number" placeholder="Baseline %" class="manual-metric-baseline" style="flex:1;min-width:80px;padding:0.5rem 0.7rem;border:1px solid #ddd;border-radius:4px;font-size:0.85rem;font-family:Inter,sans-serif;" />
                                                <input type="number" placeholder="Target %" class="manual-metric-target" style="flex:1;min-width:80px;padding:0.5rem 0.7rem;border:1px solid #ddd;border-radius:4px;font-size:0.85rem;font-family:Inter,sans-serif;" />
                                                <select class="manual-metric-domain" style="flex:1;min-width:140px;padding:0.5rem 0.7rem;border:1px solid #ddd;border-radius:4px;font-size:0.85rem;font-family:Inter,sans-serif;">
                                                    <option value="">Link to domain...</option>
                                                </select>
                                            </div>
                                        </div>
                                        <div style="display:flex;gap:0.75rem;margin-top:0.75rem;">
                                            <button class="btn btn-action" onclick="addManualMetricRow()" style="font-size:0.85rem;">+ Add Metric</button>
                                            <button class="btn btn-ai" onclick="generateGoalsFromData()" style="font-size:0.85rem;">Generate Goals from Data</button>
                                        </div>
                                    </div>
                                    <div id="dataAnalysisOutput" class="ai-response-area"></div>
                                </div>

                                <h2 style="font-family:'Source Serif Pro',serif;font-size:1.25rem;color:#22333B;margin:1.5rem 0 0.75rem;">Suggested Goals</h2>
                                <div id="suggestedGoalsContainer"></div>
                                <h2 style="font-family:'Source Serif Pro',serif;font-size:1.25rem;color:#22333B;margin-top:1.5rem;margin-bottom:0.75rem;">Your Goals</h2>
                                <div id="goalsContainer"></div>
                                <div class="custom-input-section"><button class="btn btn-action" onclick="addGoal()">Add Custom Goal</button></div>
                                <div id="aiGoalsOutput" class="ai-response-area"></div>
                                <div id="aiGoalEvalOutput" class="ai-response-area"></div>

                                <div class="equity-lens-section" style="margin-top:2rem;padding:1.5rem;background:linear-gradient(135deg,#f0f7f7,#f7f5f0);border:2px solid #00B4CC;border-radius:12px;">
                                    <h4 style="font-family:'Plus Jakarta Sans',sans-serif;font-size:1rem;font-weight:700;color:#22333B;margin:0 0 0.5rem 0;">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="#00B4CC" stroke-width="2" width="20" height="20" style="vertical-align:middle;margin-right:6px;"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
                                        Equity Lens: Subgroup Goals
                                    </h4>
                                    <p style="font-size:0.85rem;color:#5E503F;margin-bottom:1.25rem;">Set differentiated targets for student subgroups to ensure your plan explicitly addresses equity gaps. Research shows that aggregate goals can mask inequities.</p>
                                    
                                    <div id="equitySubgroupContainer">
                                        <!-- Rendered dynamically per goal -->
                                    </div>
                                    
                                    <button class="btn btn-ai" onclick="renderEquitySubgroups()" style="margin-top:1rem;">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16" style="margin-right:6px;"><path d="M12 5v14M5 12h14"/></svg>
                                        Generate Subgroup Targets
                                    </button>
                                </div>

                                <div class="section-divider"></div>
                                <div class="feedback-entry">
                                    <h4><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16" style="vertical-align:-3px;margin-right:6px;"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>Stakeholder Feedback on Goals</h4>
                                    <p style="font-size:0.82rem;color:var(--brown);margin:0 0 10px 0;">Record what staff and community members said about priorities and targets.</p>
                                    <textarea id="stakeholderFeedback6" placeholder="What goals did staff prioritize? Were targets seen as achievable? Any pushback or new ideas?" oninput="saveStakeholderFeedback(6, this.value)"></textarea>
                                </div>
                            </div>
                        </div>

                        <!-- GUIDED STEP 4: Finalize, Grade & Report -->
                        <div class="guided-step collapsed" id="gs-6-4">
                            <div class="guided-step-header" onclick="toggleGuidedStep(this)">
                                <div class="guided-step-number">4</div>
                                <h3>Finalize, Grade & Report</h3>
                                <span class="substep-status status-todo" id="gs-6-4-status">To Do</span>
                                <svg class="guided-step-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><polyline points="6 9 12 15 18 9"/></svg>
                            </div>
                            <div class="guided-step-body">
                                <p class="substep-desc">Grade your strategic goals, review improvement tips, and download your section report.</p>
                                <div class="section-grader" id="grader-stage-6">
                                    <div class="section-grader-top">
                                        <div class="section-grade-circle" id="grade-circle-6">--</div>
                                        <div class="section-grader-info">
                                            <h3>Strategic Goals Grade</h3>
                                            <p id="grade-summary-6">Set your goals to receive a grade.</p>
                                        </div>
                                    </div>
                                    <div class="section-grader-criteria" id="grade-criteria-6">
                                        <div class="grader-criterion"><span class="criterion-dot" id="crit-6-1"></span>Each domain has at least 1 goal</div>
                                        <div class="grader-criterion"><span class="criterion-dot" id="crit-6-2"></span>Goals follow SMART format</div>
                                        <div class="grader-criterion"><span class="criterion-dot" id="crit-6-3"></span>Goals reference measurable metrics</div>
                                        <div class="grader-criterion"><span class="criterion-dot" id="crit-6-4"></span>Goals align with vision and domains</div>
                                        <div class="grader-criterion"><span class="criterion-dot" id="crit-6-5"></span>Stakeholder feedback was recorded</div>
                                        <div class="grader-criterion"><span class="criterion-dot" id="crit-6-6"></span>Equity subgroup targets set for key populations</div>
                                    </div>
                                    <button class="grader-btn" onclick="gradeSection(6)">Grade My Work</button>
                                    <div class="grader-tips" id="grade-tips-6"><h4>How to Improve</h4><ul id="grade-tips-list-6"></ul></div>
                                </div>
                                <div class="section-report-download" style="margin-top:1.5rem;">
                                    <div class="report-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="24" height="24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg></div>
                                    <div class="report-info"><h4>Strategic Goals Report</h4><p>SMART goals with alignment analysis</p></div>
                                    <button class="btn-report" onclick="generateGoalsReportPDF(planState)">Download PDF</button>
                                </div>
                            </div>
                        </div>

                    </div><!-- /.guided-steps -->

                    <div class="step-actions-bar"><button class="btn btn-clear" onclick="clearStep(6)">Clear This Step</button></div>
                    <div class="button-group">
                        <button class="btn btn-save" onclick="saveAndConfirm(this)">Save Progress</button>
                        <button class="btn btn-secondary" onclick="stepPrev()">Previous</button>
                        <button class="btn btn-primary" onclick="stepNext()">Next</button>
                    </div>
                </div>

                <!-- STEP 7: Strategic Goal Forecasting -->
                <div class="step-content" data-step="7">
                    <div class="step-actions-bar"><button class="btn btn-clear" onclick="clearStep(7)">Clear This Step</button></div>
                    <h1 class="step-title">Strategic Goal Forecasting</h1>
                    <div class="section-purpose">Based on your goals, here's where your district is headed. Adjust the ambition level to set targets that are both challenging and achievable. These projections use research-based improvement rates benchmarked against national data.</div>

                    <div class="guided-steps">

                        <!-- GUIDED STEP 1: Learn & Prepare -->
                        <div class="guided-step" id="gs-7-1">
                            <div class="guided-step-header" onclick="toggleGuidedStep(this)">
                                <div class="guided-step-number">1</div>
                                <h3>Learn & Prepare</h3>
                                <span class="substep-status status-todo" id="gs-7-1-status">To Do</span>
                                <svg class="guided-step-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><polyline points="6 9 12 15 18 9"/></svg>
                            </div>
                            <div class="guided-step-body">
                                <p class="substep-desc">Review scenario planning tools and board presentation templates before setting your forecasts.</p>
                                <div class="doc-download-grid">
                                    <div class="doc-download-card"><span class="doc-type-badge pdf">PDF</span><h4>Scenario Analysis</h4><p>Best/likely/worst scenario comparisons.</p><button class="btn btn-download" onclick="generateScenarioAnalysisPDF(planState)">Download PDF</button></div>
                                    <div class="doc-download-card"><span class="doc-type-badge pptx">PPTX</span><h4>Board Explanation Slides</h4><p>Present forecasting methodology to the board.</p><button class="btn btn-download" onclick="generateBoardForecastPPTX(planState)">Download PPTX</button></div>
                                </div>
                                <div style="margin-top:1rem; text-align:right;">
                                    <button class="btn btn-action" onclick="markGuidedStepDone('7','1')">I've reviewed the resources</button>
                                </div>
                            </div>
                        </div>

                        <!-- GUIDED STEP 2: Build Your Forecasts -->
                        <div class="guided-step collapsed" id="gs-7-2">
                            <div class="guided-step-header" onclick="toggleGuidedStep(this)">
                                <div class="guided-step-number">2</div>
                                <h3>Build Your Forecasts</h3>
                                <span class="substep-status status-todo" id="gs-7-2-status">To Do</span>
                                <svg class="guided-step-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><polyline points="6 9 12 15 18 9"/></svg>
                            </div>
                            <div class="guided-step-body">
                                <p class="substep-desc">Review your data profile, adjust ambition levels per metric, and use AI to generate improvement scenarios or run sensitivity analysis.</p>
                                <div id="dataProfileContainer"></div>
                                <div id="aiForecastOutput" class="ai-response-area"></div>
                                <div id="aiSensitivityOutput" class="ai-response-area"></div>
                                
                                <div class="multiyear-section" style="margin-top:2rem;">
                                    <h4 style="font-family:'Plus Jakarta Sans',sans-serif;font-size:1rem;font-weight:700;color:#22333B;margin:0 0 0.5rem 0;">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="#D4A537" stroke-width="2" width="20" height="20" style="vertical-align:middle;margin-right:6px;"><path d="M12 8v4l3 3"/><circle cx="12" cy="12" r="10"/></svg>
                                        Multi-Year Projection (3-5 Years)
                                    </h4>
                                    <p style="font-size:0.85rem;color:#5E503F;margin-bottom:1rem;">Project targets across multiple years. Research-based improvement rates for K-12 typically range from 2-5% annually for most metrics.</p>
                                    
                                    <div style="display:flex;gap:0.75rem;margin-bottom:1.25rem;flex-wrap:wrap;">
                                        <label style="display:flex;align-items:center;gap:6px;font-size:0.85rem;color:#5E503F;font-weight:600;">
                                            Plan Duration:
                                            <select id="multiyearDuration" onchange="renderMultiyearTable()" style="padding:6px 12px;border:1px solid #e0d8cf;border-radius:6px;font-family:Inter,sans-serif;font-size:0.85rem;">
                                                <option value="3">3 Years</option>
                                                <option value="4">4 Years</option>
                                                <option value="5" selected>5 Years</option>
                                            </select>
                                        </label>
                                        <label style="display:flex;align-items:center;gap:6px;font-size:0.85rem;color:#5E503F;font-weight:600;">
                                            Start Year:
                                            <select id="multiyearStartYear" onchange="renderMultiyearTable()" style="padding:6px 12px;border:1px solid #e0d8cf;border-radius:6px;font-family:Inter,sans-serif;font-size:0.85rem;">
                                                <option value="2024">2024-25</option>
                                                <option value="2025" selected>2025-26</option>
                                                <option value="2026">2026-27</option>
                                                <option value="2027">2027-28</option>
                                            </select>
                                        </label>
                                    </div>
                                    
                                    <div id="multiyearTableContainer" style="overflow-x:auto;">
                                        <!-- Rendered dynamically -->
                                    </div>
                                    
                                    <div style="display:flex;gap:0.75rem;margin-top:1rem;">
                                        <button class="btn btn-ai" onclick="autoProjectTargets()">Auto-Project Targets</button>
                                        <button class="btn btn-save" onclick="saveMultiyearData()">Save Projections</button>
                                    </div>
                                    
                                    <div id="multiyearVisualization" style="margin-top:1.5rem;">
                                        <!-- Simple trend visualization rendered here -->
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- GUIDED STEP 3: Finalize, Grade & Report -->
                        <div class="guided-step collapsed" id="gs-7-3">
                            <div class="guided-step-header" onclick="toggleGuidedStep(this)">
                                <div class="guided-step-number">3</div>
                                <h3>Finalize, Grade & Report</h3>
                                <span class="substep-status status-todo" id="gs-7-3-status">To Do</span>
                                <svg class="guided-step-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><polyline points="6 9 12 15 18 9"/></svg>
                            </div>
                            <div class="guided-step-body">
                                <p class="substep-desc">Grade your forecasts, review improvement tips, and download your forecasting report.</p>
                                <div class="section-grader" id="grader-stage-7">
                                    <div class="section-grader-top">
                                        <div class="section-grade-circle" id="grade-circle-7">--</div>
                                        <div class="section-grader-info">
                                            <h3>Forecasting Grade</h3>
                                            <p id="grade-summary-7">Enter baseline data and targets to receive a grade.</p>
                                        </div>
                                    </div>
                                    <div class="section-grader-criteria" id="grade-criteria-7">
                                        <div class="grader-criterion"><span class="criterion-dot" id="crit-7-1"></span>Baseline data entered for key metrics</div>
                                        <div class="grader-criterion"><span class="criterion-dot" id="crit-7-2"></span>Improvement targets set for each goal</div>
                                        <div class="grader-criterion"><span class="criterion-dot" id="crit-7-3"></span>Targets are realistic based on research</div>
                                        <div class="grader-criterion"><span class="criterion-dot" id="crit-7-4"></span>Multi-year projections (3+ years)</div>
                                        <div class="grader-criterion"><span class="criterion-dot" id="crit-7-5"></span>Multi-year projections set for at least 3 years</div>
                                    </div>
                                    <button class="grader-btn" onclick="gradeSection(7)">Grade My Work</button>
                                    <div class="grader-tips" id="grade-tips-7"><h4>How to Improve</h4><ul id="grade-tips-list-7"></ul></div>
                                </div>
                                <div class="section-report-download" style="margin-top:1.5rem;">
                                    <div class="report-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="24" height="24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg></div>
                                    <div class="report-info"><h4>Forecasting Report</h4><p>Full forecasting report with trend charts</p></div>
                                    <button class="btn-report" onclick="generateForecastReportPDF(planState)">Download PDF</button>
                                </div>
                            </div>
                        </div>

                    </div><!-- /.guided-steps -->

                    <div class="step-actions-bar"><button class="btn btn-clear" onclick="clearStep(7)">Clear This Step</button></div>
                    <div class="button-group">
                        <button class="btn btn-save" onclick="saveAndConfirm(this)">Save Progress</button>
                        <button class="btn btn-secondary" onclick="stepPrev()">Previous</button>
                        <button class="btn btn-primary" onclick="stepNext()">Next</button>
                    </div>
                </div>

                <!-- STEP 8: Central Office Alignment -->
                <div class="step-content" data-step="8">
                    <div class="step-actions-bar"><button class="btn btn-clear" onclick="clearStep(8)">Clear This Step</button></div>
                    <h1 class="step-title">Central Office Alignment</h1>
                    <div class="section-purpose">Every department in your central office should support your strategic goals. Here you'll map which departments drive which goals so everyone knows how they contribute.</div>

                    <div class="guided-steps">

                        <!-- GUIDED STEP 1: Learn & Prepare -->
                        <div class="guided-step" id="gs-8-1">
                            <div class="guided-step-header" onclick="toggleGuidedStep(this)">
                                <div class="guided-step-number">1</div>
                                <h3>Learn & Prepare</h3>
                                <span class="substep-status status-todo" id="gs-8-1-status">To Do</span>
                                <svg class="guided-step-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><polyline points="6 9 12 15 18 9"/></svg>
                            </div>
                            <div class="guided-step-body">
                                <p class="substep-desc">Download RACI charts and communication templates. Every employee should understand how their work connects to the strategic plan.</p>
                                <div class="doc-download-grid">
                                    <div class="doc-download-card"><span class="doc-type-badge docx">DOCX</span><h4>Responsibility Chart</h4><p>RACI-style accountability chart.</p><button class="btn btn-download" onclick="generateResponsibilityChartDOCX(planState)">Download DOCX</button></div>
                                    <div class="doc-download-card"><span class="doc-type-badge docx">DOCX</span><h4>Department Communication</h4><p>Communication template for each department.</p><button class="btn btn-download" onclick="generateDeptCommsTemplateDOCX(planState,'all')">Download DOCX</button></div>
                                </div>
                                <div style="margin-top:1rem; text-align:right;">
                                    <button class="btn btn-action" onclick="markGuidedStepDone('8','1')">I've reviewed the resources</button>
                                </div>
                            </div>
                        </div>

                        <!-- GUIDED STEP 2: Engage Department Leaders -->
                        <div class="guided-step collapsed" id="gs-8-2">
                            <div class="guided-step-header" onclick="toggleGuidedStep(this)">
                                <div class="guided-step-number">2</div>
                                <h3>Engage Department Leaders</h3>
                                <span class="substep-status status-todo" id="gs-8-2-status">To Do</span>
                                <svg class="guided-step-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><polyline points="6 9 12 15 18 9"/></svg>
                            </div>
                            <div class="guided-step-body">
                                <p class="substep-desc">Hold department town halls and collect feedback on how each team sees their role in the strategic plan.</p>
                                <div class="engagement-checklist">
                                    <label class="engagement-check-label"><input type="checkbox" id="engageDeptLeaders" /> Department leader meetings completed</label>
                                    <label class="engagement-check-label"><input type="checkbox" id="engageDeptTownHalls" /> Department town halls scheduled</label>
                                    <label class="engagement-check-label"><input type="checkbox" id="engageDeptFeedback" /> Alignment feedback collected</label>
                                </div>
                                <div class="engagement-actions">
                                    <button class="btn btn-action" onclick="generateFocusGroupGuide('alignment')">Generate Town Hall Guide</button>
                                </div>
                                <div id="alignmentWorkshopOutput" class="toolkit-output-area"></div>
                                <div style="margin-top:1rem; text-align:right;">
                                    <button class="btn btn-action" onclick="markGuidedStepDone('8','2')">Department engagement planned</button>
                                </div>
                            </div>
                        </div>

                        <!-- GUIDED STEP 3: Map Alignment -->
                        <div class="guided-step collapsed" id="gs-8-3">
                            <div class="guided-step-header" onclick="toggleGuidedStep(this)">
                                <div class="guided-step-number">3</div>
                                <h3>Map Department Alignment</h3>
                                <span class="substep-status status-todo" id="gs-8-3-status">To Do</span>
                                <svg class="guided-step-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><polyline points="6 9 12 15 18 9"/></svg>
                            </div>
                            <div class="guided-step-body">
                                <p class="substep-desc">Select departments, map them to goals, and define each department's role. Use the AI helper to detect alignment gaps.</p>
                                <h2 style="font-family:'Source Serif Pro',serif;font-size:1.25rem;color:#22333B;margin-bottom:0.75rem;">Select Departments</h2>
                                <button class="btn btn-action" onclick="autoSelectDepartments()" style="margin-bottom:1rem;">Auto-Select from Domains</button>
                                <div id="departmentSelectionContainer"></div>
                                <div style="margin-top:1.5rem;padding:1.25rem;background:#fafafa;border-radius:8px;border:2px dashed #ccc">
                                    <h3 style="font-family:Source Serif Pro,serif;font-size:1rem;color:#22333B;margin:0 0 0.5rem 0">Add a Department</h3>
                                    <p style="font-size:0.82rem;color:#888;margin:0 0 0.75rem 0">Don't see your department? Add it here.</p>
                                    <div style="display:flex;gap:0.75rem;flex-wrap:wrap">
                                        <input type="text" id="customDeptName" placeholder="Department name" style="flex:1;min-width:200px;padding:0.5rem 0.7rem;border:1px solid #ddd;border-radius:4px;font-size:0.85rem;font-family:Inter,sans-serif" />
                                        <input type="text" id="customDeptDesc" placeholder="Brief description" style="flex:1;min-width:180px;padding:0.5rem 0.7rem;border:1px solid #ddd;border-radius:4px;font-size:0.85rem;font-family:Inter,sans-serif" />
                                        <button onclick="addCustomDepartment()" style="padding:0.5rem 1rem;background:#00B4CC;color:white;border:none;border-radius:4px;cursor:pointer;font-size:0.85rem;font-weight:600">Add</button>
                                    </div>
                                </div>
                                <h2 style="font-family:'Source Serif Pro',serif;font-size:1.25rem;color:#22333B;margin-top:1.5rem;margin-bottom:0.75rem;">Alignment Matrix</h2>
                                <div id="alignmentMatrixContainer"></div>
                                <h2 style="font-family:'Source Serif Pro',serif;font-size:1.25rem;color:#22333B;margin-top:1.5rem;margin-bottom:0.75rem;">Department Details</h2>
                                <div id="departmentDetailsContainer"></div>
                                <div id="aiAlignmentOutput" class="ai-response-area"></div>

                                <div class="section-divider"></div>
                                <div class="feedback-entry">
                                    <h4><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16" style="vertical-align:-3px;margin-right:6px;"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>Department Leader Feedback</h4>
                                    <p style="font-size:0.82rem;color:var(--brown);margin:0 0 10px 0;">Record what department leaders said about alignment, capacity, and coordination needs.</p>
                                    <textarea id="stakeholderFeedback8" placeholder="What did department leaders say about their capacity? Any concerns about overload or coordination gaps?" oninput="saveStakeholderFeedback(8, this.value)"></textarea>
                                </div>
                            </div>
                        </div>

                        <!-- GUIDED STEP 4: Finalize, Grade & Report -->
                        <div class="guided-step collapsed" id="gs-8-4">
                            <div class="guided-step-header" onclick="toggleGuidedStep(this)">
                                <div class="guided-step-number">4</div>
                                <h3>Finalize, Grade & Report</h3>
                                <span class="substep-status status-todo" id="gs-8-4-status">To Do</span>
                                <svg class="guided-step-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><polyline points="6 9 12 15 18 9"/></svg>
                            </div>
                            <div class="guided-step-body">
                                <p class="substep-desc">Grade your alignment work, review improvement tips, and download your section report.</p>
                                <div class="section-grader" id="grader-stage-8">
                                    <div class="section-grader-top">
                                        <div class="section-grade-circle" id="grade-circle-8">--</div>
                                        <div class="section-grader-info">
                                            <h3>Alignment Grade</h3>
                                            <p id="grade-summary-8">Map departments to goals to receive a grade.</p>
                                        </div>
                                    </div>
                                    <div class="section-grader-criteria" id="grade-criteria-8">
                                        <div class="grader-criterion"><span class="criterion-dot" id="crit-8-1"></span>All goals mapped to at least one department</div>
                                        <div class="grader-criterion"><span class="criterion-dot" id="crit-8-2"></span>No department overloaded (5+ goals)</div>
                                        <div class="grader-criterion"><span class="criterion-dot" id="crit-8-3"></span>Cross-department coordination identified</div>
                                        <div class="grader-criterion"><span class="criterion-dot" id="crit-8-4"></span>Clear accountability assignments</div>
                                        <div class="grader-criterion"><span class="criterion-dot" id="crit-8-5"></span>Department leader feedback was recorded</div>
                                    </div>
                                    <button class="grader-btn" onclick="gradeSection(8)">Grade My Work</button>
                                    <div class="grader-tips" id="grade-tips-8"><h4>How to Improve</h4><ul id="grade-tips-list-8"></ul></div>
                                </div>
                                <div class="section-report-download" style="margin-top:1.5rem;">
                                    <div class="report-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="24" height="24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg></div>
                                    <div class="report-info"><h4>Alignment Report</h4><p>Department alignment analysis with matrix</p></div>
                                    <button class="btn-report" onclick="generateAlignmentReportPDF(planState)">Download PDF</button>
                                </div>
                            </div>
                        </div>

                    </div><!-- /.guided-steps -->

                    <div class="step-actions-bar" style="margin-top:2.5rem;"><button class="btn btn-clear" onclick="clearStep(8)">Clear This Step</button></div>
                    <div class="button-group">
                        <button class="btn btn-save" onclick="saveAndConfirm(this)">Save Progress</button>
                        <button class="btn btn-secondary" onclick="stepPrev()">Previous</button>
                        <button class="btn btn-primary" onclick="stepNext()">Next</button>
                    </div>
                </div>

                <!-- STEP 9: Action Initiatives -->
                <div class="step-content" data-step="9">
                    <div class="step-actions-bar"><button class="btn btn-clear" onclick="clearStep(9)">Clear This Step</button></div>
                    <h1 class="step-title">Action Initiatives</h1>
                    <div class="section-purpose">Initiatives are the concrete projects and programs you'll run to achieve your goals. We'll suggest evidence-based practices, then you can add your own based on what your district needs.</div>

                    <div class="guided-steps">

                        <!-- GUIDED STEP 1: Learn & Prepare -->
                        <div class="guided-step" id="gs-9-1">
                            <div class="guided-step-header" onclick="toggleGuidedStep(this)">
                                <div class="guided-step-number">1</div>
                                <h3>Learn & Prepare</h3>
                                <span class="substep-status status-todo" id="gs-9-1-status">To Do</span>
                                <svg class="guided-step-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><polyline points="6 9 12 15 18 9"/></svg>
                            </div>
                            <div class="guided-step-body">
                                <p class="substep-desc">Download proposal templates and prioritization tools. Strong initiatives are evidence-based, resourced, and clearly owned.</p>
                                <div class="doc-download-grid">
                                    <div class="doc-download-card"><span class="doc-type-badge docx">DOCX</span><h4>Initiative Proposal Template</h4><p>Editable proposal template for individual initiatives.</p><button class="btn btn-download" onclick="generateInitiativeProposalDOCX(planState,'all')">Download DOCX</button></div>
                                    <div class="doc-download-card"><span class="doc-type-badge pdf">PDF</span><h4>Prioritization Matrix</h4><p>Impact vs. effort visual matrix.</p><button class="btn btn-download" onclick="generatePrioritizationMatrixPDF(planState)">Download PDF</button></div>
                                </div>
                                <div style="margin-top:1rem; text-align:right;">
                                    <button class="btn btn-action" onclick="markGuidedStepDone('9','1')">I've reviewed the resources</button>
                                </div>
                            </div>
                        </div>

                        <!-- GUIDED STEP 2: Select & Build Initiatives -->
                        <div class="guided-step collapsed" id="gs-9-2">
                            <div class="guided-step-header" onclick="toggleGuidedStep(this)">
                                <div class="guided-step-number">2</div>
                                <h3>Select & Build Initiatives</h3>
                                <span class="substep-status status-todo" id="gs-9-2-status">To Do</span>
                                <svg class="guided-step-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><polyline points="6 9 12 15 18 9"/></svg>
                            </div>
                            <div class="guided-step-body">
                                <p class="substep-desc">Select 5 to 7 initiatives that will drive progress toward your strategic goals. Use the AI helper to suggest evidence-based options or prioritize by impact.</p>
                                <h2 style="font-family:'Source Serif Pro',serif;font-size:1.25rem;color:#22333B;margin-bottom:0.75rem;">Suggested Initiatives</h2>
                                <div id="suggestedInitiativesContainer"></div>
                                <h2 style="font-family:'Source Serif Pro',serif;font-size:1.25rem;color:#22333B;margin-top:1.5rem;margin-bottom:0.75rem;">Your Initiatives</h2>
                                <div id="initiativesContainer"></div>
                                <div class="custom-input-section"><button class="btn btn-action" onclick="addInitiative()">Add Custom Initiative</button></div>
                                <div class="counter-bar">Selected: <span id="initiativeCounter">0</span> initiatives</div>
                                <div id="aiInitiativesOutput" class="ai-response-area"></div>
                                <div id="aiPrioritizeOutput" class="ai-response-area"></div>

                                <!-- Budget & Funding Alignment Section -->
                                <div class="budget-alignment-section" style="margin-top:1.5rem;">
                                    <h4 style="font-family:'Plus Jakarta Sans',sans-serif;font-size:0.95rem;font-weight:700;color:#22333B;margin-bottom:1rem;">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="#D4A537" stroke-width="2" width="18" height="18" style="vertical-align:middle;margin-right:6px;"><path d="M12 1v22M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
                                        Budget & Funding Alignment
                                    </h4>
                                    <p style="font-size:0.85rem;color:#5E503F;margin-bottom:1rem;">Estimate costs and identify funding sources for each initiative. This builds your financial roadmap.</p>
                                    
                                    <div id="budgetAlignmentContainer">
                                        <!-- Populated dynamically based on initiatives -->
                                    </div>
                                    
                                    <div class="budget-summary-card" id="budgetSummaryCard" style="display:none;margin-top:1.5rem;padding:1.25rem;background:linear-gradient(135deg,#f7f5f2,#ffffff);border:1px solid #e0d8cf;border-radius:10px;">
                                        <h4 style="margin:0 0 0.75rem 0;font-size:0.9rem;font-weight:700;color:#22333B;">Budget Summary</h4>
                                        <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:1rem;">
                                            <div><div style="font-size:0.75rem;color:#888;text-transform:uppercase;letter-spacing:0.5px;">Total Estimated</div><div id="budgetTotal" style="font-family:'Source Serif Pro',serif;font-size:1.5rem;font-weight:700;color:#22333B;">$0</div></div>
                                            <div><div style="font-size:0.75rem;color:#888;text-transform:uppercase;letter-spacing:0.5px;">Funded</div><div id="budgetFunded" style="font-family:'Source Serif Pro',serif;font-size:1.5rem;font-weight:700;color:#00B4CC;">$0</div></div>
                                            <div><div style="font-size:0.75rem;color:#888;text-transform:uppercase;letter-spacing:0.5px;">Gap</div><div id="budgetGap" style="font-family:'Source Serif Pro',serif;font-size:1.5rem;font-weight:700;color:#D4A537;">$0</div></div>
                                        </div>
                                        <div style="margin-top:0.75rem;height:8px;background:#E8E8E8;border-radius:4px;overflow:hidden;">
                                            <div id="budgetFundedBar" style="height:100%;width:0%;border-radius:4px;background:linear-gradient(90deg,#00B4CC,#2EC4B6);transition:width 0.8s ease;"></div>
                                        </div>
                                        <div id="fundingBreakdown" style="margin-top:1rem;display:flex;flex-wrap:wrap;gap:0.5rem;"></div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- GUIDED STEP 3: Finalize, Grade & Report -->
                        <div class="guided-step collapsed" id="gs-9-3">
                            <div class="guided-step-header" onclick="toggleGuidedStep(this)">
                                <div class="guided-step-number">3</div>
                                <h3>Finalize, Grade & Report</h3>
                                <span class="substep-status status-todo" id="gs-9-3-status">To Do</span>
                                <svg class="guided-step-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><polyline points="6 9 12 15 18 9"/></svg>
                            </div>
                            <div class="guided-step-body">
                                <p class="substep-desc">Grade your initiatives, review improvement tips, and download your section report.</p>
                                <div class="section-grader" id="grader-stage-9">
                                    <div class="section-grader-top">
                                        <div class="section-grade-circle" id="grade-circle-9">--</div>
                                        <div class="section-grader-info">
                                            <h3>Initiatives Grade</h3>
                                            <p id="grade-summary-9">Select your initiatives to receive a grade.</p>
                                        </div>
                                    </div>
                                    <div class="section-grader-criteria" id="grade-criteria-9">
                                        <div class="grader-criterion"><span class="criterion-dot" id="crit-9-1"></span>Each goal has at least one initiative</div>
                                        <div class="grader-criterion"><span class="criterion-dot" id="crit-9-2"></span>Resource estimates included</div>
                                        <div class="grader-criterion"><span class="criterion-dot" id="crit-9-3"></span>Initiative owners assigned</div>
                                        <div class="grader-criterion"><span class="criterion-dot" id="crit-9-4"></span>Impact vs. effort considered</div>
                                    </div>
                                    <button class="grader-btn" onclick="gradeSection(9)">Grade My Work</button>
                                    <div class="grader-tips" id="grade-tips-9"><h4>How to Improve</h4><ul id="grade-tips-list-9"></ul></div>
                                </div>
                                <div class="section-report-download" style="margin-top:1.5rem;">
                                    <div class="report-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="24" height="24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg></div>
                                    <div class="report-info"><h4>Initiative Portfolio</h4><p>Complete initiative portfolio with details</p></div>
                                    <button class="btn-report" onclick="generateInitiativesReportPDF(planState)">Download PDF</button>
                                </div>
                            </div>
                        </div>

                    </div><!-- /.guided-steps -->

                    <div class="step-actions-bar"><button class="btn btn-clear" onclick="clearStep(9)">Clear This Step</button></div>
                    <div class="button-group">
                        <button class="btn btn-save" onclick="saveAndConfirm(this)">Save Progress</button>
                        <button class="btn btn-secondary" onclick="stepPrev()">Previous</button>
                        <button class="btn btn-primary" onclick="stepNext()">Next</button>
                    </div>
                </div>

                <!-- STEP 10: Implementation Calendar -->
                <div class="step-content" data-step="10">
                    <div class="step-actions-bar"><button class="btn btn-clear" onclick="clearStep(10)">Clear This Step</button></div>
                    <h1 class="step-title">Implementation Calendar</h1>
                    <div class="section-purpose">A strategic plan without a timeline is just a wish list. This calendar maps out milestones, progress check-ins, and accountability workshops for your Superintendent, Board, and every department you selected.</div>

                    <div class="guided-steps">

                        <!-- GUIDED STEP 1: Learn & Prepare -->
                        <div class="guided-step" id="gs-10-1">
                            <div class="guided-step-header" onclick="toggleGuidedStep(this)">
                                <div class="guided-step-number">1</div>
                                <h3>Learn & Prepare</h3>
                                <span class="substep-status status-todo" id="gs-10-1-status">To Do</span>
                                <svg class="guided-step-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><polyline points="6 9 12 15 18 9"/></svg>
                            </div>
                            <div class="guided-step-body">
                                <p class="substep-desc">Download milestone tracking tools and board presentation templates for your implementation timeline.</p>
                                <div class="doc-download-grid">
                                    <div class="doc-download-card"><span class="doc-type-badge docx">DOCX</span><h4>Milestone Plan</h4><p>Detailed milestone tracking document.</p><button class="btn btn-download" onclick="generateMilestonePlanDOCX(planState)">Download DOCX</button></div>
                                    <div class="doc-download-card"><span class="doc-type-badge pptx">PPTX</span><h4>Board Timeline Slides</h4><p>Implementation timeline for board presentation.</p><button class="btn btn-download" onclick="generateBoardTimelinePPTX(planState)">Download PPTX</button></div>
                                </div>
                                <div style="margin-top:1rem; text-align:right;">
                                    <button class="btn btn-action" onclick="markGuidedStepDone('10','1')">I've reviewed the resources</button>
                                </div>
                            </div>
                        </div>

                        <!-- GUIDED STEP 2: Build Your Calendar -->
                        <div class="guided-step collapsed" id="gs-10-2">
                            <div class="guided-step-header" onclick="toggleGuidedStep(this)">
                                <div class="guided-step-number">2</div>
                                <h3>Build Your Calendar</h3>
                                <span class="substep-status status-todo" id="gs-10-2-status">To Do</span>
                                <svg class="guided-step-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><polyline points="6 9 12 15 18 9"/></svg>
                            </div>
                            <div class="guided-step-body">
                                <p class="substep-desc">Set your school year and start month, then review the auto-generated calendar. Use the AI helper to generate a multi-year roadmap or identify risks.</p>
                                <div style="display:flex;gap:16px;margin-bottom:20px;flex-wrap:wrap;">
                                    <div style="flex:1;min-width:200px;">
                                        <label style="display:block;font-weight:700;color:var(--navy);font-size:13px;margin-bottom:6px;">School Year</label>
                                        <select id="calendarYear" onchange="renderImplementationCalendar()" style="width:100%;padding:10px 12px;border:2px solid #E8E8E8;border-radius:8px;font-size:14px;font-family:Inter,sans-serif;">
                                            <option value="2024-25">2024-25</option>
                                            <option value="2025-26" selected>2025-26</option>
                                            <option value="2026-27">2026-27</option>
                                            <option value="2027-28">2027-28</option>
                                            <option value="2028-29">2028-29</option>
                                            <option value="2029-30">2029-30</option>
                                        </select>
                                    </div>
                                    <div style="flex:1;min-width:200px;">
                                        <label style="display:block;font-weight:700;color:var(--navy);font-size:13px;margin-bottom:6px;">Plan Start Month (Optional)</label>
                                        <select id="calendarStartMonth" onchange="renderImplementationCalendar()" style="width:100%;padding:10px 12px;border:2px solid #E8E8E8;border-radius:8px;font-size:14px;font-family:Inter,sans-serif;">
                                            <option value="7">July (Default)</option>
                                            <option value="8">August</option>
                                            <option value="9">September</option>
                                            <option value="1">January</option>
                                            <option value="6">June</option>
                                        </select>
                                    </div>
                                </div>
                                <div id="implementationCalendarContainer"></div>
                                <div id="aiTimelineOutput" class="ai-response-area"></div>
                                <div id="aiRisksOutput" class="ai-response-area"></div>
                            </div>
                        </div>

                        <!-- GUIDED STEP 3: Finalize, Grade & Report -->
                        <div class="guided-step collapsed" id="gs-10-3">
                            <div class="guided-step-header" onclick="toggleGuidedStep(this)">
                                <div class="guided-step-number">3</div>
                                <h3>Finalize, Grade & Report</h3>
                                <span class="substep-status status-todo" id="gs-10-3-status">To Do</span>
                                <svg class="guided-step-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><polyline points="6 9 12 15 18 9"/></svg>
                            </div>
                            <div class="guided-step-body">
                                <p class="substep-desc">Grade your implementation calendar, review improvement tips, and download your roadmap.</p>
                                <div class="section-grader" id="grader-stage-10">
                                    <div class="section-grader-top">
                                        <div class="section-grade-circle" id="grade-circle-10">--</div>
                                        <div class="section-grader-info">
                                            <h3>Implementation Calendar Grade</h3>
                                            <p id="grade-summary-10">Build your calendar to receive a grade.</p>
                                        </div>
                                    </div>
                                    <div class="section-grader-criteria" id="grade-criteria-10">
                                        <div class="grader-criterion"><span class="criterion-dot" id="crit-10-1"></span>All initiatives scheduled on calendar</div>
                                        <div class="grader-criterion"><span class="criterion-dot" id="crit-10-2"></span>Milestones defined for each initiative</div>
                                        <div class="grader-criterion"><span class="criterion-dot" id="crit-10-3"></span>Board reporting dates included</div>
                                        <div class="grader-criterion"><span class="criterion-dot" id="crit-10-4"></span>Timeline is realistic and achievable</div>
                                    </div>
                                    <button class="grader-btn" onclick="gradeSection(10)">Grade My Work</button>
                                    <div class="grader-tips" id="grade-tips-10"><h4>How to Improve</h4><ul id="grade-tips-list-10"></ul></div>
                                </div>
                                <div class="section-report-download" style="margin-top:1.5rem;">
                                    <div class="report-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="24" height="24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg></div>
                                    <div class="report-info"><h4>Multi-Year Roadmap</h4><p>Visual implementation roadmap</p></div>
                                    <button class="btn-report" onclick="generateRoadmapPDF(planState)">Download PDF</button>
                                </div>
                            </div>
                        </div>

                    </div><!-- /.guided-steps -->

                    <div class="step-actions-bar" style="margin-top:2.5rem;"><button class="btn btn-clear" onclick="clearStep(10)">Clear This Step</button></div>
                    <div class="button-group">
                        <button class="btn btn-save" onclick="saveAndConfirm(this)">Save Progress</button>
                        <button class="btn btn-secondary" onclick="stepPrev()">Previous</button>
                        <button class="btn btn-primary" onclick="stepNext()">Next</button>
                    </div>
                </div>

                <!-- STEP 11: Review & Finalize -->
                <div class="step-content" data-step="11">
                    <!-- Strategic Plan Feasibility Score -->
                    <div class="feasibility-dashboard" id="feasibilityDashboard">
                        <h1 class="step-title" style="margin-bottom:0.5rem;">Strategic Plan Feasibility</h1>
                        <div class="section-purpose">Your plan is scored across five dimensions. A strong plan scores above 80% across all categories.</div>

                        <div class="feasibility-gauge-container" style="text-align:center;margin:2rem 0;">
                            <div class="feasibility-gauge" id="feasibilityGauge" style="display:inline-flex;flex-direction:column;align-items:center;justify-content:center;width:180px;height:180px;border-radius:50%;border:8px solid #E8E8E8;background:linear-gradient(135deg,#f7f5f2,#ffffff);position:relative;">
                                <div class="feasibility-grade" id="feasibilityGrade" style="font-family:'Source Serif Pro',serif;font-size:3.5rem;font-weight:700;color:var(--navy);line-height:1;">--</div>
                                <div style="font-size:0.75rem;font-weight:600;color:var(--brown);text-transform:uppercase;letter-spacing:1px;">Overall Score</div>
                            </div>
                        </div>

                        <div class="feasibility-categories" style="display:grid;gap:1rem;margin-top:1.5rem;">
                            <div class="feasibility-category">
                                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;">
                                    <span style="font-weight:600;color:var(--navy);font-size:0.9rem;">Completeness</span>
                                    <span class="feasibility-category-score" id="feasCompleteness" style="font-weight:700;font-size:0.9rem;">0%</span>
                                </div>
                                <div style="height:8px;background:#E8E8E8;border-radius:4px;overflow:hidden;"><div id="feasCompletenessBar" style="height:100%;width:0%;border-radius:4px;background:var(--pop-teal);transition:width 1s ease;"></div></div>
                                <p style="font-size:0.8rem;color:#888;margin-top:4px;">All planning stages thoroughly completed.</p>
                            </div>
                            <div class="feasibility-category">
                                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;">
                                    <span style="font-weight:600;color:var(--navy);font-size:0.9rem;">Alignment</span>
                                    <span class="feasibility-category-score" id="feasAlignment" style="font-weight:700;font-size:0.9rem;">0%</span>
                                </div>
                                <div style="height:8px;background:#E8E8E8;border-radius:4px;overflow:hidden;"><div id="feasAlignmentBar" style="height:100%;width:0%;border-radius:4px;background:var(--pop-teal);transition:width 1s ease;"></div></div>
                                <p style="font-size:0.8rem;color:#888;margin-top:4px;">Vision, mission, values, domains, and goals are coherent.</p>
                            </div>
                            <div class="feasibility-category">
                                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;">
                                    <span style="font-weight:600;color:var(--navy);font-size:0.9rem;">Stakeholder Engagement</span>
                                    <span class="feasibility-category-score" id="feasEngagement" style="font-weight:700;font-size:0.9rem;">0%</span>
                                </div>
                                <div style="height:8px;background:#E8E8E8;border-radius:4px;overflow:hidden;"><div id="feasEngagementBar" style="height:100%;width:0%;border-radius:4px;background:var(--pop-teal);transition:width 1s ease;"></div></div>
                                <p style="font-size:0.8rem;color:#888;margin-top:4px;">Community input was gathered and incorporated.</p>
                            </div>
                            <div class="feasibility-category">
                                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;">
                                    <span style="font-weight:600;color:var(--navy);font-size:0.9rem;">Data Quality</span>
                                    <span class="feasibility-category-score" id="feasDataQuality" style="font-weight:700;font-size:0.9rem;">0%</span>
                                </div>
                                <div style="height:8px;background:#E8E8E8;border-radius:4px;overflow:hidden;"><div id="feasDataQualityBar" style="height:100%;width:0%;border-radius:4px;background:var(--pop-teal);transition:width 1s ease;"></div></div>
                                <p style="font-size:0.8rem;color:#888;margin-top:4px;">Goals and forecasts grounded in real performance data.</p>
                            </div>
                            <div class="feasibility-category">
                                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;">
                                    <span style="font-weight:600;color:var(--navy);font-size:0.9rem;">Implementation Readiness</span>
                                    <span class="feasibility-category-score" id="feasReadiness" style="font-weight:700;font-size:0.9rem;">0%</span>
                                </div>
                                <div style="height:8px;background:#E8E8E8;border-radius:4px;overflow:hidden;"><div id="feasReadinessBar" style="height:100%;width:0%;border-radius:4px;background:var(--pop-teal);transition:width 1s ease;"></div></div>
                                <p style="font-size:0.8rem;color:#888;margin-top:4px;">Initiatives mapped, calendar built, departments aligned.</p>
                            </div>
                            <div class="feasibility-category">
                                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;">
                                    <span style="font-weight:600;color:var(--navy);font-size:0.9rem;">Equity & Access</span>
                                    <span class="feasibility-category-score" id="feasEquity" style="font-weight:700;font-size:0.9rem;">0%</span>
                                </div>
                                <div style="height:8px;background:#E8E8E8;border-radius:4px;overflow:hidden;"><div id="feasEquityBar" style="height:100%;width:0%;border-radius:4px;background:var(--pop-teal);transition:width 1s ease;"></div></div>
                                <p style="font-size:0.8rem;color:#888;margin-top:4px;">Subgroup goals set, equity gaps addressed, differentiated strategies included.</p>
                            </div>
                        </div>

                        <button class="btn btn-ai" onclick="calculateFeasibility()" style="margin-top:1.5rem;width:100%;">Calculate Feasibility Score</button>
                        <button class="btn btn-secondary" onclick="generateDriftReport()" style="margin-top:0.75rem;width:100%;">Run AI Drift Detection</button>
                        <div id="feasibilityFeedback" class="toolkit-output-area" style="margin-top:1rem;"></div>
                    </div>

                    <!-- Existing Review Content -->
                    <div id="reviewChecklist"></div>
                    <div id="reviewContainer"></div>

                    <!-- Finalize section -->
                    <div id="finalizeSection" style="display:none;text-align:center;margin:2rem 0;padding:2rem;background:linear-gradient(135deg,#f0f7f7,#f7f5f0);border-radius:10px;border:2px solid #00B4CC;">
                        <h3 style="font-family:Source Serif Pro,serif;color:#22333B;margin:0 0 0.5rem 0">Ready to Finalize</h3>
                        <p style="font-size:0.9rem;color:#5E503F;margin:0 0 1.25rem 0">All steps complete. Lock your plan to enable exports and school-level alignment.</p>
                        <button class="btn btn-primary" onclick="finalizePlan()" style="font-size:1rem;padding:0.75rem 2.5rem">Finalize Plan</button>
                    </div>

                    <div id="exportSection" style="display:none">
                        <h2 style="font-family:'Source Serif Pro',serif;font-size:1.4rem;color:#22333B;margin-bottom:1.5rem;">Export Your Plan</h2>
                        <div class="export-group">
                            <button class="export-btn" onclick="exportDashboardHTML()">Strategic Plan Dashboard</button>
                            <button class="export-btn" onclick="exportQuickSummary()">Quick Summary (PDF)</button>
                            <button class="export-btn" onclick="exportFullPlan()">Full Strategic Plan</button>
                        </div>
                        <div style="margin-top:2rem;padding:1.5rem;background-color:#f0f8f0;border-left:4px solid #6ECF6E;border-radius:4px;">
                            <h3 style="color:#22333B;margin-top:0;">Plan Finalized</h3>
                            <p style="color:#5E503F;">Your strategic plan has been finalized and saved. Share it with your leadership team, building principals, and board.</p>
                        </div>
                    </div>

                    <div class="engagement-callout">
                        <div class="engagement-callout-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></div>
                        <div class="engagement-callout-content">
                            <h4>Close the Loop with Stakeholders</h4>
                            <p>Before finalizing, present the full plan to your board, community advisory groups, and staff.</p>
                        </div>
                    </div>

                    <!-- INLINE AI -->
                    <div class="ai-inline-assist">
                        <div class="ai-sparkle"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M12 2l2.4 7.4H22l-6.2 4.5L18.2 22 12 17.5 5.8 22l2.4-8.1L2 9.4h7.6z"/></svg></div>
                        <span>AI generates a polished executive summary of your plan</span>
                        <button class="btn-ai-inline" onclick="aiGenerateExecutiveSummary()">Generate Summary</button>
                    </div>
                    <div id="aiExecSummaryOutput" class="ai-response-area"></div>

                    <!-- TOOLKIT: Resources & Templates -->
                    <div class="toolkit-substep" data-type="resources">
                        <div class="toolkit-substep-header" onclick="toggleSubstep(this)"><div class="toolkit-substep-left"><span class="toolkit-substep-type-badge resources">Resources & Templates</span><h3>Final Deliverables</h3></div><svg class="toolkit-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><polyline points="6 9 12 15 18 9"/></svg></div>
                        <div class="toolkit-substep-content" style="display:none;">
                            <p class="toolkit-substep-description">Your complete strategic plan deliverables, ready for board adoption and community distribution.</p>
                            <div class="doc-download-grid">
                                <div class="doc-download-card"><span class="doc-type-badge pdf">PDF</span><h4>Full Strategic Plan</h4><p>Complete strategic plan document for board adoption.</p><button class="btn btn-download" onclick="generateStrategicPlanPDF(planState)">Download PDF</button></div>
                                <div class="doc-download-card"><span class="doc-type-badge pdf">PDF</span><h4>Executive Summary</h4><p>Two-page executive overview of the strategic plan.</p><button class="btn btn-download" onclick="generateExecutiveSummaryPDF(planState)">Download PDF</button></div>
                                <div class="doc-download-card"><span class="doc-type-badge pptx">PPTX</span><h4>Board Adoption Slides</h4><p>Presentation for formal board adoption of the plan.</p><button class="btn btn-download" onclick="generateBoardAdoptionPPTX(planState)">Download PPTX</button></div>
                                <div class="doc-download-card"><span class="doc-type-badge pdf">PDF</span><h4>Community Plan Summary</h4><p>Public-facing plan summary for families and community.</p><button class="btn btn-download" onclick="generateCommunityPlanPDF(planState)">Download PDF</button></div>
                                <div class="doc-download-card"><span class="doc-type-badge pdf">PDF</span><h4>Feasibility Report</h4><p>Detailed feasibility analysis with recommendations.</p><button class="btn btn-download" onclick="generateFeasibilityReportPDF(planState)">Download PDF</button></div>
                            </div>
                        </div>
                    </div>

                    <!-- Progress Dashboard Link -->
                    <div style="margin-top:2rem;padding:1.5rem;background:linear-gradient(135deg,#22333B,#2d4a5a);border-radius:12px;text-align:center;">
                        <h3 style="font-family:'Source Serif Pro',serif;color:#fff;margin:0 0 0.5rem 0;">Track Your Progress</h3>
                        <p style="color:rgba(255,255,255,0.8);font-size:0.9rem;margin:0 0 1.25rem 0;">After finalizing, use the Progress Monitoring Dashboard to track KPIs, detect drift, and stay on course.</p>
                        <a href="dashboard.html" class="btn btn-primary" style="display:inline-block;text-decoration:none;background:#00B4CC;padding:0.75rem 2rem;">Open Progress Dashboard</a>
                    </div>

                    <div class="button-group" style="margin-top:2.5rem">
                        <button class="btn btn-save" onclick="saveAndConfirm(this)">Save Progress</button>
                        <button class="btn btn-secondary" onclick="stepPrev()">Previous</button>
                    </div>
                </div>
            </div>

            <!-- Preview Panel -->
            <div class="preview-panel">
                <div class="preview-header">
                    <h3>Plan Preview</h3>
                </div>
                <div id="previewContent" class="preview-content">
                    <div class="preview-placeholder">Your plan will appear here as you build it.</div>
                </div>
            </div>
        </div>
    </div>

    <script src="js/builder.js"></script>
    <script src="js/paywall.js"></script>
    <script src="js/ai-engine.js"></script>
    <script src="js/doc-generator.js"></script>
    <script src="js/toolkit.js"></script>
    <script src="js/budget-alignment.js"></script>
    <script src="js/features.js"></script>
    <script>
      window.stepGoto = stepGotoWithPaywall;
      window.stepNext = stepNextWithPaywall;
    </script>
</body>
</html>